@model CGA.MetrologySystem.Domain.Entities.Laboratorio

@{
    ViewData["Title"] = "Detalle del laboratorio";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Detalle del laboratorio</h2>
        <p class="page-subtitle">
            Consulta la información completa del laboratorio seleccionado.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="form-card">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Nombre</label>
            <input class="form-control readonly-highlight" value="@Model.Nombre" readonly />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Norma de acreditación</label>
            <input class="form-control readonly-highlight" value="@Model.NormaAcreditacion" readonly />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Dirección</label>
        <input class="form-control readonly-highlight" value="@Model.Direccion" readonly />
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Ciudad</label>
            <input class="form-control readonly-highlight" value="@Model.Ciudad" readonly />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">País</label>
            <input class="form-control readonly-highlight" value="@Model.Pais" readonly />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Estado</label>
            <input class="form-control readonly-highlight" value="@(Model.Activo ? "Activo" : "Inactivo")" readonly />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Teléfono</label>
            <input class="form-control readonly-highlight" value="@Model.Telefono" readonly />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Correo electrónico</label>
            <input class="form-control readonly-highlight" value="@Model.Email" readonly />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Sitio web</label>
        <input class="form-control readonly-highlight" value="@Model.SitioWeb" readonly />
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Edit" asp-route-id="@Model.LaboratorioId" class="btn btn-primary">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</div>