@model IEnumerable<CGA.MetrologySystem.Domain.Entities.Laboratorio>

@{
    ViewData["Title"] = "Laboratorios";
    var puedeGestionarLaboratorios = !User.IsInRole(RolesSistema.AdministradorSistema) &&
        User.IsInRole(RolesSistema.AdministradorMetrologico);
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Laboratorios</h2>
        <p class="page-subtitle">
            Gestiona los laboratorios registrados en el sistema.
        </p>
    </div>
    @if (puedeGestionarLaboratorios)
    {
        <a asp-action="Create" class="btn btn-primary">Nuevo laboratorio</a>
    }
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Ciudad</th>
                    <th>País</th>
                    <th>Alcance</th>
                    <th>Norma</th>
                    <th>N° acreditación</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>@item.Ciudad</td>
                            <td>@item.Pais</td>
                            <td>@item.Alcance</td>
                            <td>@item.NormaAcreditacion</td>
                            <td>@item.NumeroAcreditacion</td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.LaboratorioId" class="btn btn-sm btn-outline-secondary">
                                        Detalles
                                    </a>
                                    @if (puedeGestionarLaboratorios)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.LaboratorioId" class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.LaboratorioId" class="btn btn-sm btn-outline-danger">
                                            Eliminar
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No existen laboratorios registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
