@model CGA.MetrologySystem.Domain.Entities.EventoVerificacionDato

@{
    ViewData["Title"] = "Detalle de verificación";

    var evento = Model.EventoMetrologico;

    var estado = evento.EstadoEquipoResultado ?? "Sin estado";

    var badgeClass = estado switch
    {
        "Operativo" => "bg-success",
        "No Operativo" => "bg-danger",
        "Fuera de Servicio" => "bg-dark",
        _ => "bg-secondary"
    };
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">

    <div>

        <h2 class="page-title">Detalle de verificación</h2>

        <p class="page-subtitle">
            Información técnica del evento, resultados evaluados y evidencias visuales registradas.
        </p>

    </div>

    <div class="d-flex gap-2">

        @if (!evento.Anulado && evento.Activo &&
            (!evento.EsHistorico || User.IsInRole("Administrador")))
        {
            <a asp-action="Edit"
                   asp-route-id="@Model.EventoVerificacionDatoId"
                   class="btn btn-primary">
                Editar
            </a>
        }

        @if (!evento.Anulado && evento.Activo && User.IsInRole("Administrador"))
        {
            <a asp-action="Anular"
               asp-route-id="@Model.EventoVerificacionDatoId"
               class="btn btn-outline-danger">
                Anular
            </a>
        }

        <a asp-action="Index"
               class="btn btn-outline-secondary">
            Volver
        </a>

    </div>

</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="row">

    <div class="col-lg-8 mb-4">

        <div class="form-card h-100">

            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">

                <div>

                    <h5 class="mb-1">
                        @evento.Equipo?.Codigo - @evento.Equipo?.Nombre
                    </h5>

                    <p class="text-muted mb-0">
                        Verificación técnica registrada
                    </p>

                </div>

                <div>

                    <span class="badge @badgeClass fs-6">
                        @estado
                    </span>

                    @if (evento.EsExtraordinario)
                    {
                        <span class="badge bg-warning text-dark fs-6 ms-1">
                            Extraordinaria
                        </span>
                    }

                    @if (evento.EsHistorico)
                    {
                        <span class="badge bg-info text-dark fs-6 ms-1">
                            Histórica
                        </span>
                    }

                    @if (evento.Anulado)
                    {
                        <span class="badge bg-danger fs-6 ms-1">
                            Anulada
                        </span>
                    }

                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-4 mb-3">

                    <div class="text-muted small">
                        Fecha de verificación
                    </div>

                    <div class="fw-semibold">
                        @evento.FechaEvento.ToString("yyyy-MM-dd")
                    </div>

                </div>

                <div class="col-md-4 mb-3">

                    <div class="text-muted small">
                        Próxima fecha
                    </div>

                    <div class="fw-semibold">

                        @(evento.FechaProxima.HasValue
                            ? evento.FechaProxima.Value.ToString("yyyy-MM-dd")
                            : "No definida")

                    </div>

                </div>

                <div class="col-md-4 mb-3">

                    <div class="text-muted small">
                        Responsable interno
                    </div>

                    <div class="fw-semibold">
                        @evento.ResponsableInterno?.NombreCompleto
                    </div>

                </div>

                <div class="col-md-4 mb-3">

                    <div class="text-muted small">
                        Subtipo de evento
                    </div>

                    <div class="fw-semibold">
                        @evento.SubtipoEvento?.Nombre
                    </div>

                </div>

                <div class="col-md-4 mb-3">

                    <div class="text-muted small">
                        Fecha de registro
                    </div>

                    <div class="fw-semibold">
                        @evento.FechaRegistro.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </div>

                </div>

            </div>

            @if (!string.IsNullOrWhiteSpace(evento.ComentariosAdicionales))
            {
                <div class="mb-4">

                    <div class="text-muted small mb-1">
                        Comentarios adicionales
                    </div>

                    <div class="border rounded p-3 bg-light">
                        @evento.ComentariosAdicionales
                    </div>

                </div>
            }

            @if (evento.EsExtraordinario)
            {
                <div class="alert alert-warning">

                    <div class="fw-semibold mb-1">
                        Justificación extraordinaria
                    </div>

                    <div>

                        @(string.IsNullOrWhiteSpace(evento.JustificacionExtraordinario)
                            ? "No se registró una justificación."
                            : evento.JustificacionExtraordinario)

                    </div>

                </div>
            }

            @if (evento.EsHistorico && !string.IsNullOrWhiteSpace(evento.ObservacionCargaHistorica))
            {
                <div class="alert alert-info">
                    <div class="fw-semibold mb-1">
                        Observación histórica
                    </div>

                    <div>
                        @evento.ObservacionCargaHistorica
                    </div>
                </div>
            }

            @if (evento.Anulado)
            {
                <div class="alert alert-danger">
                    <div class="fw-semibold mb-1">
                        Anulación metrológica
                    </div>

                    <div>
                        <strong>Fecha:</strong>
                        @(evento.FechaAnulacion.HasValue
                            ? evento.FechaAnulacion.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            : "No definida")
                    </div>

                    <div>
                        <strong>Responsable:</strong>
                        @(string.IsNullOrWhiteSpace(evento.UsuarioAnulacionNombre)
                            ? "No identificado"
                            : evento.UsuarioAnulacionNombre)
                    </div>

                    <div class="mt-2">
                        <strong>Motivo:</strong>
                        @(string.IsNullOrWhiteSpace(evento.MotivoAnulacion)
                            ? "No registrado"
                            : evento.MotivoAnulacion)
                    </div>
                </div>
            }

            <hr class="my-4" />

            <h5 class="mb-3">
                Resultados de verificación
            </h5>

            @if (evento.ResultadosVerificacion != null && evento.ResultadosVerificacion.Any())
            {
                <div class="table-responsive checklist-table-shell checklist-detail-scroll mx-0 mb-0">

                    <table class="table checklist-table align-middle mb-0">

                        <thead>
                            <tr>
                                <th class="checklist-head-order checklist-order-column">#</th>
                                <th class="checklist-head-description">Condición evaluada</th>
                                <th class="checklist-head-status checklist-status-column">Resultado</th>
                                <th class="checklist-head-notes">Observaciones</th>
                                <th class="checklist-head-evidence">Evidencia del ítem</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var resultado in evento.ResultadosVerificacion.OrderBy(r => r.Orden))
                            {
                                <tr class="checklist-row @(resultado.Cumple ? "checklist-row-pass" : "checklist-row-fail")">

                                    <td>
                                        <span class="checklist-row-number">
                                            @resultado.Orden
                                        </span>
                                    </td>

                                    <td class="fw-semibold">
                                        @resultado.DescripcionItem
                                    </td>

                                    <td>

                                        @if (resultado.Cumple)
                                        {
                                            <span class="checklist-result-badge checklist-result-pass">
                                                Cumple
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="checklist-result-badge checklist-result-fail">
                                                No cumple
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (!string.IsNullOrWhiteSpace(resultado.Observaciones))
                                        {
                                            @resultado.Observaciones
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                Sin observaciones
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(resultado.EvidenciaGoogleDriveFileId))
                                        {
                                            <a asp-controller="Documentos"
                                               asp-action="VerImagen"
                                               asp-route-tipo="evidencia-verificacion-item"
                                               asp-route-id="@resultado.EventoVerificacionResultadoId"
                                               class="btn btn-outline-primary btn-sm"
                                               title="@resultado.EvidenciaNombreArchivo">
                                                Ver imagen
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                Sin imagen
                                            </span>
                                        }
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-light border">
                    No existen resultados registrados.
                </div>
            }

        </div>

    </div>

    <div class="col-lg-4 mb-4">

        <div class="form-card mb-4">

            <h5 class="mb-3">
                Documento generado
            </h5>

            @if (!string.IsNullOrWhiteSpace(Model.RutaPdf))
            {
                <p class="text-muted">
                    El PDF interno fue generado automáticamente y almacenado en Google Drive.
                </p>

                <div class="d-grid gap-2">

                    <a asp-controller="Documentos"
                       asp-action="VerPdf"
                       asp-route-tipo="verificacion"
                       asp-route-id="@Model.EventoVerificacionDatoId"
                       class="btn btn-primary">
                        Ver PDF
                    </a>

                </div>

                <div class="mt-3 small text-muted text-break">
                    @Model.NombreArchivoPdf
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    Esta verificación aún no tiene PDF asociado.
                </div>
            }

        </div>

        <div class="form-card">

            <h5 class="mb-3">
                Evidencias visuales
            </h5>

            @if (evento.Evidencias != null && evento.Evidencias.Any(e => e.Activo))
            {
                <div class="d-grid gap-3">

                    @foreach (var evidencia in evento.Evidencias
                                            .Where(e => e.Activo)
                                            .OrderByDescending(e => e.FechaCarga))
                    {
                        <div class="border rounded p-3">

                            <div class="fw-semibold text-truncate">
                                @evidencia.NombreArchivo
                            </div>

                            <div class="text-muted small mb-2">
                                @evidencia.FechaCarga.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </div>

                            <a asp-controller="Documentos"
                               asp-action="VerImagen"
                               asp-route-tipo="evidencia-evento"
                               asp-route-id="@evidencia.EvidenciaEventoMetrologicoId"
                               class="btn btn-outline-primary btn-sm">
                                Abrir evidencia
                            </a>

                        </div>
                    }

                </div>
            }
            else
            {
                <div class="alert alert-light border mb-0">
                    No existen evidencias visuales registradas.
                </div>
            }

        </div>

    </div>

</div>
