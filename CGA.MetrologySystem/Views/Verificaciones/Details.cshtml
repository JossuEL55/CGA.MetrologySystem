@model CGA.MetrologySystem.Domain.Entities.EventoVerificacionDato

@{
    ViewData["Title"] = "Detalle de verificación";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Detalle de verificación</h2>
        <p class="page-subtitle">Información completa de la verificación registrada.</p>
    </div>

    <div class="section-actions">
        <a asp-action="Edit" asp-route-id="@Model.EventoVerificacionDatoId" class="btn btn-primary">Editar</a>

        @if (!string.IsNullOrWhiteSpace(Model.RutaPdf))
        {
            <a href="@Model.RutaPdf" target="_blank" class="btn btn-outline-danger">Ver PDF</a>
        }

        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</div>

<div class="form-card">
    <h5 class="mb-3">Datos generales</h5>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Equipo</label>
            <input class="form-control readonly-highlight"
                   value="@Model.EventoMetrologico.Equipo.Codigo - @Model.EventoMetrologico.Equipo.Nombre" readonly />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Subtipo de evento</label>
            <input class="form-control readonly-highlight"
                   value="@Model.EventoMetrologico.SubtipoEvento.Nombre" readonly />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Responsable interno</label>
            <input class="form-control readonly-highlight"
                   value="@Model.EventoMetrologico.ResponsableInterno.NombreCompleto" readonly />
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">Fecha de verificación</label>
            <input class="form-control readonly-highlight"
                   value="@Model.EventoMetrologico.FechaEvento.ToString("yyyy-MM-dd")" readonly />
        </div>

        <div class="col-md-3 mb-3">
            <label class="form-label fw-semibold">Próxima fecha</label>
            <input class="form-control readonly-highlight"
                   value="@(Model.EventoMetrologico.FechaProxima.HasValue ? Model.EventoMetrologico.FechaProxima.Value.ToString("yyyy-MM-dd") : "N/D")"
                   readonly />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Estado del equipo</label>
            <input class="form-control readonly-highlight"
                   value="@Model.EventoMetrologico.EstadoEquipoResultado" readonly />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Extraordinario</label>
            <input class="form-control readonly-highlight"
                   value="@(Model.EventoMetrologico.EsExtraordinario ? "Sí" : "No")" readonly />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">PDF</label>
            <input class="form-control readonly-highlight"
                   value="@(!string.IsNullOrWhiteSpace(Model.RutaPdf) ? "Documento disponible" : "Sin PDF")"
                   readonly />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Comentarios adicionales</label>
        <textarea class="form-control readonly-highlight" rows="3" readonly>@Model.EventoMetrologico.ComentariosAdicionales</textarea>
    </div>

    @if (Model.EventoMetrologico.EsExtraordinario)
    {
        <div class="mb-3">
            <label class="form-label fw-semibold">Justificación extraordinaria</label>
            <textarea class="form-control readonly-highlight" rows="2" readonly>@Model.EventoMetrologico.JustificacionExtraordinario</textarea>
        </div>
    }

    <hr class="my-4" />

    <h5 class="mb-3">Condiciones verificadas</h5>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width: 80px;">Orden</th>
                    <th>Condición</th>
                    <th style="width: 130px;">Resultado</th>
                    <th>Observaciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.EventoMetrologico.ResultadosVerificacion == null || !Model.EventoMetrologico.ResultadosVerificacion.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            No existen condiciones registradas para esta verificación.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var resultado in Model.EventoMetrologico.ResultadosVerificacion.OrderBy(r => r.Orden))
                    {
                        <tr>
                            <td>@resultado.Orden</td>
                            <td>@resultado.DescripcionItem</td>
                            <td>
                                <span class="badge @(resultado.Cumple ? "bg-success" : "bg-danger")">
                                    @(resultado.Cumple ? "Cumple" : "No cumple")
                                </span>
                            </td>
                            <td>@resultado.Observaciones</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>