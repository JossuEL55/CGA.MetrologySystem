@model CGA.MetrologySystem.Models.VerificacionViewModel

@{
    ViewData["Title"] = "Crear verificación";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Crear verificación</h2>
        <p class="page-subtitle">Registra una nueva verificación para un equipo.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<form asp-action="Create" method="post" class="form-card">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="EquipoId" class="form-label fw-semibold"></label>
            <select asp-for="EquipoId"
                    asp-items="Model.Equipos"
                    class="form-control"
                    id="EquipoId">
                <option value="">Seleccione un equipo...</option>
            </select>
            <span asp-validation-for="EquipoId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="SubtipoEventoId" class="form-label fw-semibold"></label>
            <select asp-for="SubtipoEventoId"
                    asp-items="Model.SubtiposEvento"
                    class="form-control">
                <option value="">Seleccione un subtipo...</option>
            </select>
            <span asp-validation-for="SubtipoEventoId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ResponsableInternoId" class="form-label fw-semibold"></label>
            <select asp-for="ResponsableInternoId"
                    asp-items="Model.ResponsablesInternos"
                    class="form-control">
                <option value="">Seleccione un responsable...</option>
            </select>
            <span asp-validation-for="ResponsableInternoId" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="FechaEvento" class="form-label fw-semibold"></label>
            <input asp-for="FechaEvento" class="form-control" type="date" />
            <span asp-validation-for="FechaEvento" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="FechaProxima" class="form-label fw-semibold"></label>
            <input asp-for="FechaProxima" class="form-control" type="date" />
            <span asp-validation-for="FechaProxima" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="EstadoEquipoResultado" class="form-label fw-semibold"></label>
        <select asp-for="EstadoEquipoResultado" class="form-control">
            <option value="">Seleccione...</option>
            <option value="Operativo">Operativo</option>
            <option value="No Operativo">No Operativo</option>
            <option value="Fuera de Servicio">Fuera de Servicio</option>
        </select>
        <span asp-validation-for="EstadoEquipoResultado" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ComentariosAdicionales" class="form-label fw-semibold"></label>
        <textarea asp-for="ComentariosAdicionales" class="form-control" rows="3"></textarea>
        <span asp-validation-for="ComentariosAdicionales" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="EsExtraordinario" class="form-check-input" />
        <label asp-for="EsExtraordinario" class="form-check-label fw-semibold"></label>
    </div>

    <div class="mb-4">
        <label asp-for="JustificacionExtraordinario" class="form-label fw-semibold"></label>
        <textarea asp-for="JustificacionExtraordinario" class="form-control" rows="2"></textarea>
        <span asp-validation-for="JustificacionExtraordinario" class="text-danger"></span>
    </div>

    <hr />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h5 class="mb-0">Condiciones a verificar</h5>
            <small class="text-muted">
                Al seleccionar un equipo, se cargará automáticamente la plantilla de verificación correspondiente.
            </small>
        </div>
        <button type="button" id="addResultado" class="btn btn-outline-primary btn-sm">
            Agregar condición
        </button>
    </div>

    <table class="table table-hover align-middle" id="tablaResultados">
        <thead>
            <tr>
                <th>Condición a verificar</th>
                <th style="width: 120px;">Cumple</th>
                <th>Observaciones</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Resultados.Count; i++)
            {
                <tr>
                    <td>
                        <input type="hidden" asp-for="Resultados[i].Orden" />
                        <input asp-for="Resultados[i].DescripcionItem"
                               class="form-control"
                               placeholder="Condición a verificar" />
                        <span asp-validation-for="Resultados[i].DescripcionItem" class="text-danger"></span>
                    </td>
                    <td class="text-center">
                        <input type="hidden" name="Resultados[@i].Cumple" value="false" />
                        <input type="checkbox"
                               name="Resultados[@i].Cumple"
                               value="true"
                               class="form-check-input"
                        @(Model.Resultados[i].Cumple ? "checked" : "") />
                    </td>
                    <td>
                        <input asp-for="Resultados[i].Observaciones"
                               class="form-control"
                               placeholder="Observaciones" />
                    </td>
                    <td>
                        <button type="button" class="btn btn-outline-danger btn-sm eliminar">X</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">Guardar</button>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let index = @Model.Resultados.Count;

        document.addEventListener("DOMContentLoaded", function () {
            const equipoSelect = document.getElementById("EquipoId");

            if (equipoSelect) {
                equipoSelect.addEventListener("change", function () {
                    const equipoId = this.value;

                    if (!equipoId || equipoId === "0") {
                        return;
                    }

                    window.location.href = `/Verificaciones/Create?equipoId=${equipoId}`;
                });
            }

            const addResultadoButton = document.getElementById("addResultado");

            if (addResultadoButton) {
                addResultadoButton.addEventListener("click", function () {
                    const fila = `
                        <tr>
                            <td>
                                <input type="hidden" name="Resultados[${index}].Orden" value="${index + 1}" />
                                <input name="Resultados[${index}].DescripcionItem"
                                       class="form-control"
                                       placeholder="Condición a verificar" />
                            </td>
                            <td class="text-center">
                                <input type="hidden" name="Resultados[${index}].Cumple" value="false" />
                                <input type="checkbox"
                                       name="Resultados[${index}].Cumple"
                                       value="true"
                                       class="form-check-input"
                                       checked />
                            </td>
                            <td>
                                <input name="Resultados[${index}].Observaciones"
                                       class="form-control"
                                       placeholder="Observaciones" />
                            </td>
                            <td>
                                <button type="button" class="btn btn-outline-danger btn-sm eliminar">X</button>
                            </td>
                        </tr>`;

                    document.querySelector("#tablaResultados tbody").insertAdjacentHTML("beforeend", fila);
                    index++;
                });
            }
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("eliminar")) {
                e.target.closest("tr").remove();
            }
        });
    </script>
}