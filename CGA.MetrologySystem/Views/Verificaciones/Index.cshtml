@model IEnumerable<CGA.MetrologySystem.Domain.Entities.EventoVerificacionDato>

@{
    ViewData["Title"] = "Verificaciones";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Verificaciones</h2>
        <p class="page-subtitle">Listado de verificaciones registradas para los equipos.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nueva verificación</a>
</div>

<div class="form-card">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Equipo</th>
                <th>Responsable</th>
                <th>Fecha</th>
                <th>Próxima fecha</th>
                <th>Estado</th>
                <th>PDF</th>
                <th style="width: 220px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <strong>@item.EventoMetrologico.Equipo.Codigo</strong><br />
                        <span class="text-muted">@item.EventoMetrologico.Equipo.Nombre</span>
                    </td>
                    <td>@item.EventoMetrologico.ResponsableInterno.NombreCompleto</td>
                    <td>@item.EventoMetrologico.FechaEvento.ToString("yyyy-MM-dd")</td>
                    <td>
                        @(item.EventoMetrologico.FechaProxima.HasValue
                            ? item.EventoMetrologico.FechaProxima.Value.ToString("yyyy-MM-dd")
                            : "N/D")
                    </td>
                    <td>@item.EventoMetrologico.EstadoEquipoResultado</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.RutaPdf))
                        {
                            <a href="@item.RutaPdf" target="_blank" class="btn btn-outline-danger btn-sm">
                                Ver PDF
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Sin PDF</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@item.EventoVerificacionDatoId" class="btn btn-outline-info btn-sm">Detalle</a>
                            <a asp-action="Edit" asp-route-id="@item.EventoVerificacionDatoId" class="btn btn-outline-primary btn-sm">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.EventoVerificacionDatoId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>