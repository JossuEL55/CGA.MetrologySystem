@model IEnumerable<CGA.MetrologySystem.Domain.Entities.EventoVerificacionDato>

@{
    ViewData["Title"] = "Verificaciones";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Verificaciones</h2>

        <p class="page-subtitle">
            Consulta el historial de verificaciones técnicas, resultados evaluados y documentación generada automáticamente.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Registrar verificación
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="form-card">

    @if (!Model.Any())
    {
        <div class="text-center py-5">

            <h5 class="mb-2">Aún no hay verificaciones registradas</h5>

            <p class="text-muted mb-4">
                Cuando registres una verificación aparecerá aquí junto con su PDF, resultados y próximas fechas calculadas.
            </p>

            <a asp-action="Create" class="btn btn-primary">
                Registrar primera verificación
            </a>

        </div>
    }
    else
    {
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Equipo</th>
                        <th>Fecha</th>
                        <th>Próxima fecha</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th>PDF</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        var evento = item.EventoMetrologico;

                        var estado = evento.EstadoEquipoResultado ?? "Sin estado";

                        var badgeClass = estado switch
                        {
                            "Operativo" => "bg-success",
                            "No Operativo" => "bg-danger",
                            "Fuera de Servicio" => "bg-dark",
                            _ => "bg-secondary"
                        };

                        <tr>

                            <td>

                                <div class="fw-semibold">
                                    @evento.Equipo?.Codigo
                                </div>

                                <div class="text-muted small">
                                    @evento.Equipo?.Nombre
                                </div>

                            </td>

                            <td>
                                @evento.FechaEvento.ToString("yyyy-MM-dd")
                            </td>

                            <td>

                                @if (evento.FechaProxima.HasValue)
                                {
                                    <span>
                                        @evento.FechaProxima.Value.ToString("yyyy-MM-dd")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        No definida
                                    </span>
                                }

                            </td>

                            <td>
                                @evento.ResponsableInterno?.NombreCompleto
                            </td>

                            <td>

                                <span class="badge @badgeClass">
                                    @estado
                                </span>

                                @if (evento.EsExtraordinario)
                                {
                                    <span class="badge bg-warning text-dark ms-1">
                                        Extraordinaria
                                    </span>
                                }

                            </td>

                            <td>

                                @if (!string.IsNullOrWhiteSpace(item.RutaPdf))
                                {
                                    <a href="@item.RutaPdf"
                                           target="_blank"
                                           class="btn btn-outline-primary btn-sm">
                                        Ver PDF
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">
                                        Sin PDF
                                    </span>
                                }

                            </td>

                            <td class="text-end">

                                <div class="btn-group">

                                    <a asp-action="Details"
                                           asp-route-id="@item.EventoVerificacionDatoId"
                                           class="btn btn-outline-secondary btn-sm">
                                        Detalle
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.EventoVerificacionDatoId"
                                           class="btn btn-outline-primary btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.EventoVerificacionDatoId"
                                           class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

</div>