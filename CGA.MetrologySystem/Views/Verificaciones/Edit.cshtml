@model CGA.MetrologySystem.Models.VerificacionViewModel

@{
    ViewData["Title"] = "Editar verificación";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Editar verificación</h2>
        <p class="page-subtitle">
            Actualiza la verificación técnica. El PDF será regenerado automáticamente y reemplazado en el repositorio documental.
        </p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Details"
               asp-route-id="@Model.EventoVerificacionDatoId"
               class="btn btn-outline-primary">
            Ver detalle
        </a>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>
</div>

@if (TempData["AdvertenciaRegla"] != null)
{
    <div class="alert alert-warning">
        @TempData["AdvertenciaRegla"]
    </div>
}

<form asp-action="Edit"
      asp-route-id="@Model.EventoVerificacionDatoId"
      method="post"
      enctype="multipart/form-data"
      class="form-card">

    <input asp-for="EventoMetrologicoId" type="hidden" />
    <input asp-for="EventoVerificacionDatoId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

    <div class="mb-4">
        <h5 class="mb-1">Información de la verificación</h5>

        <p class="text-muted mb-0">
            El motor de reglas recalculará automáticamente la próxima fecha del evento.
        </p>
    </div>

    <div class="row">

        <div class="col-md-6 mb-3">
            <label asp-for="EquipoId" class="form-label fw-semibold">Equipo</label>

            <select asp-for="EquipoId"
                    asp-items="Model.Equipos"
                    class="form-select">
                <option value="">Seleccione un equipo...</option>
            </select>

            <span asp-validation-for="EquipoId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="SubtipoEventoId" class="form-label fw-semibold">
                Subtipo de evento
            </label>

            <select asp-for="SubtipoEventoId"
                    asp-items="Model.SubtiposEvento"
                    class="form-select">
                <option value="">Seleccione un subtipo...</option>
            </select>

            <span asp-validation-for="SubtipoEventoId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">

        <div class="col-md-6 mb-3">
            <label asp-for="ResponsableInternoId" class="form-label fw-semibold">
                Responsable interno
            </label>

            <select asp-for="ResponsableInternoId"
                    asp-items="Model.ResponsablesInternos"
                    class="form-select">
                <option value="">Seleccione un responsable...</option>
            </select>

            <span asp-validation-for="ResponsableInternoId" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="FechaEvento" class="form-label fw-semibold">
                Fecha de verificación
            </label>

            <input asp-for="FechaEvento"
                   class="form-control"
                   type="date" />

            <span asp-validation-for="FechaEvento" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="FechaProxima" class="form-label fw-semibold">
                Próxima fecha calculada
            </label>

            <input asp-for="FechaProxima"
                   class="form-control bg-light"
                   type="date"
                   readonly
                   tabindex="-1" />

            <span asp-validation-for="FechaProxima" class="text-danger"></span>
        </div>
    </div>

    <div class="alert alert-light border mb-4">
        <strong>Nota:</strong> Si modificas la fecha de verificación, el sistema volverá a evaluar si el evento es extraordinario.
    </div>

    <div class="row">

        @if (User.IsInRole(RolesSistema.AdministradorMetrologico))
        {
            <div class="col-md-4 mb-3">
                <div class="form-check form-switch cga-switch mt-md-4 pt-md-2">
                    <input asp-for="EsHistorico" class="form-check-input" role="switch" />
                    <label asp-for="EsHistorico" class="form-check-label fw-semibold"></label>
                </div>
            </div>
        }

        <div class="col-md-4 mb-3">
            <label asp-for="EstadoEquipoResultado" class="form-label fw-semibold">
                Estado del equipo
            </label>

            <select asp-for="EstadoEquipoResultado" class="form-select">
                <option value="">Seleccione...</option>
                <option value="Operativo">Operativo</option>
                <option value="No Operativo">No Operativo</option>
                <option value="Fuera de Servicio">Fuera de Servicio</option>
            </select>

            <span asp-validation-for="EstadoEquipoResultado" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="JustificacionExtraordinario" class="form-label fw-semibold">
                Justificación extraordinaria
            </label>

            <textarea asp-for="JustificacionExtraordinario"
                      class="form-control"
                      rows="2"
                      placeholder="Completa este campo si la verificación fue extraordinaria."></textarea>

            <span asp-validation-for="JustificacionExtraordinario" class="text-danger"></span>
        </div>

        @if (User.IsInRole(RolesSistema.AdministradorMetrologico))
        {
            <div class="col-md-12 mb-3">
                <label asp-for="ObservacionCargaHistorica" class="form-label fw-semibold"></label>
                <textarea asp-for="ObservacionCargaHistorica"
                          class="form-control"
                          rows="2"
                          placeholder="Referencia u observación del registro histórico."></textarea>
                <span asp-validation-for="ObservacionCargaHistorica" class="text-danger"></span>
            </div>
        }
    </div>

    <div class="mb-4">
        <label asp-for="ComentariosAdicionales" class="form-label fw-semibold">
            Comentarios adicionales
        </label>

        <textarea asp-for="ComentariosAdicionales"
                  class="form-control"
                  rows="3"
                  placeholder="Comentarios generales de la verificación."></textarea>

        <span asp-validation-for="ComentariosAdicionales" class="text-danger"></span>
    </div>

    <hr class="my-4" />

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h5 class="mb-1">Condiciones verificadas</h5>

            <p class="text-muted mb-0">
                Puedes modificar, agregar o quitar condiciones verificadas.
            </p>
        </div>

        <button type="button" id="addResultado" class="btn btn-outline-primary">
            Agregar condición
        </button>
    </div>

    <div class="table-responsive checklist-table-shell mb-4">
        <table class="table checklist-table align-middle mb-0" id="tablaResultados">
            <thead>
                <tr>
                    <th class="checklist-head-order checklist-order-column">#</th>
                    <th class="checklist-head-description">Descripción</th>
                    <th class="checklist-head-status checklist-status-column">Cumple</th>
                    <th class="checklist-head-notes">Observaciones</th>
                    <th class="checklist-head-evidence">Evidencia del ítem</th>
                    <th class="checklist-head-action text-end checklist-action-column">Acción</th>
                </tr>
            </thead>

            <tbody>
                @for (int i = 0; i < Model.Resultados.Count; i++)
                {
                    <tr class="checklist-row" data-resultado-row>
                        <td>
                            <span class="checklist-row-number">@(i + 1)</span>
                        </td>

                        <td>

                            <input type="hidden"
                                   asp-for="Resultados[i].EventoVerificacionResultadoId"
                                   data-field="id" />

                            <input type="hidden"
                                   asp-for="Resultados[i].Orden"
                                   data-field="orden" />

                            <input asp-for="Resultados[i].DescripcionItem"
                                   data-field="descripcion"
                                   class="form-control"
                                   placeholder="Condición a verificar" />

                        </td>

                        <td class="text-center">

                            <label class="verification-check checklist-status-pill">
                                <input type="checkbox"
                                       name="Resultados[@i].Cumple"
                                       data-field="cumple"
                                       value="true"
                                       class="form-check-input"
                                @(Model.Resultados[i].Cumple ? "checked" : "") />

                                <input type="hidden"
                                       name="Resultados[@i].Cumple"
                                       data-field="cumple-hidden"
                                       value="false" />
                                <span>Sí</span>
                            </label>

                        </td>

                        <td>

                            <input asp-for="Resultados[i].Observaciones"
                                   data-field="observaciones"
                                   class="form-control"
                                   placeholder="Observaciones" />

                        </td>

                        <td>
                            <div class="checklist-evidence-actions">
                                <label class="btn btn-outline-primary btn-sm mb-0">
                                    Subir imagen
                                    <input asp-for="Resultados[i].EvidenciaImagen"
                                           data-field="evidencia"
                                           type="file"
                                           accept="image/*"
                                           class="visually-hidden" />
                                </label>

                                @if (!string.IsNullOrWhiteSpace(Model.Resultados[i].EvidenciaRutaArchivo) &&
                                                            Model.Resultados[i].EventoVerificacionResultadoId > 0)
                                {
                                    <a asp-controller="Documentos"
                                       asp-action="VerImagen"
                                       asp-route-tipo="evidencia-verificacion-item"
                                       asp-route-id="@Model.Resultados[i].EventoVerificacionResultadoId"
                                       class="btn btn-outline-secondary btn-sm"
                                       title="@Model.Resultados[i].EvidenciaNombreArchivo">
                                        Ver imagen
                                    </a>
                                }
                                else
                                {
                                    <span class="checklist-evidence-note">Sin imagen</span>
                                }
                            </div>
                        </td>

                        <td class="text-end">

                            <button type="button"
                                    class="btn btn-outline-danger btn-sm eliminar">
                                Eliminar
                            </button>

                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

    <hr class="my-4" />

    <div class="mb-4">

        <h5 class="mb-1">Evidencias visuales</h5>

        <p class="text-muted">
            Las evidencias existentes se conservarán. Puedes agregar nuevas imágenes.
        </p>

        @if (Model.EvidenciasExistentes != null && Model.EvidenciasExistentes.Any())
        {
            <div class="row mb-3">

                @foreach (var evidencia in Model.EvidenciasExistentes)
                {
                    <div class="col-md-4 mb-3">

                        <div class="border rounded p-3 h-100">

                            <div class="fw-semibold text-truncate">
                                @evidencia.NombreArchivo
                            </div>

                            <div class="text-muted small mb-2">
                                @evidencia.FechaCarga.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </div>

                            <a asp-controller="Documentos"
                               asp-action="VerImagen"
                               asp-route-tipo="evidencia-evento"
                               asp-route-id="@evidencia.EvidenciaEventoMetrologicoId"
                               class="btn btn-outline-primary btn-sm">
                                Abrir evidencia
                            </a>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="alert alert-light border">
                Esta verificación aún no tiene evidencias visuales registradas.
            </div>
        }

        <input asp-for="Evidencias"
               type="file"
               class="form-control"
               accept="image/*"
               multiple />

        <small class="text-muted">
            Puedes tomar fotografías desde el dispositivo o cargar imágenes existentes.
        </small>

    </div>

    <div class="d-flex justify-content-end gap-2">

        <a asp-action="Details"
               asp-route-id="@Model.EventoVerificacionDatoId"
               class="btn btn-outline-secondary">
            Cancelar
        </a>

        <button type="submit" class="btn btn-primary">
            Guardar cambios
        </button>

    </div>

</form>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        let index = @Model.Resultados.Count;

        function reindexarResultados() {

            document.querySelectorAll("[data-resultado-row]").forEach((row, i) => {

                const id = row.querySelector("input[data-field='id']");
                const orden = row.querySelector("input[data-field='orden']");
                const descripcion = row.querySelector("input[data-field='descripcion']");
                const cumpleHidden = row.querySelector("input[data-field='cumple-hidden']");
                const cumple = row.querySelector("input[data-field='cumple']");
                const observaciones = row.querySelector("input[data-field='observaciones']");
                const evidencia = row.querySelector("input[data-field='evidencia']");
                const number = row.querySelector(".checklist-row-number");

                if (number) number.textContent = i + 1;

                if (id) id.name = `Resultados[${i}].EventoVerificacionResultadoId`;
                if (orden) {
                    orden.name = `Resultados[${i}].Orden`;
                    orden.value = i + 1;
                }

                if (descripcion) descripcion.name = `Resultados[${i}].DescripcionItem`;
                if (cumpleHidden) cumpleHidden.name = `Resultados[${i}].Cumple`;
                if (cumple) cumple.name = `Resultados[${i}].Cumple`;
                if (observaciones) observaciones.name = `Resultados[${i}].Observaciones`;
                if (evidencia) evidencia.name = `Resultados[${i}].EvidenciaImagen`;
            });

            index = document.querySelectorAll("[data-resultado-row]").length;
        }

        document.addEventListener("DOMContentLoaded", function () {

            const addResultadoButton = document.getElementById("addResultado");

            if (addResultadoButton) {

                addResultadoButton.addEventListener("click", function () {

                    const fila = `
                        <tr class="checklist-row" data-resultado-row>
                            <td>
                                <span class="checklist-row-number">${index + 1}</span>
                            </td>

                            <td>

                                <input type="hidden"
                                       name="Resultados[${index}].EventoVerificacionResultadoId"
                                       data-field="id"
                                       value="0" />

                                <input type="hidden"
                                       name="Resultados[${index}].Orden"
                                       data-field="orden"
                                       value="${index + 1}" />

                                <input name="Resultados[${index}].DescripcionItem"
                                       data-field="descripcion"
                                       class="form-control"
                                       placeholder="Condición a verificar" />

                            </td>

                            <td class="text-center">

                                <label class="verification-check checklist-status-pill">
                                    <input type="checkbox"
                                           name="Resultados[${index}].Cumple"
                                           data-field="cumple"
                                           value="true"
                                           class="form-check-input"
                                           checked />

                                    <input type="hidden"
                                           name="Resultados[${index}].Cumple"
                                           data-field="cumple-hidden"
                                           value="false" />
                                    <span>Sí</span>
                                </label>

                            </td>

                            <td>

                                <input name="Resultados[${index}].Observaciones"
                                       data-field="observaciones"
                                       class="form-control"
                                       placeholder="Observaciones" />

                            </td>

                            <td>
                                <div class="checklist-evidence-actions">
                                    <label class="btn btn-outline-primary btn-sm mb-0">
                                        Subir imagen
                                        <input name="Resultados[${index}].EvidenciaImagen"
                                               data-field="evidencia"
                                               type="file"
                                               accept="image/*"
                                               class="visually-hidden" />
                                    </label>
                                    <span class="checklist-evidence-note">Sin imagen</span>
                                </div>
                            </td>

                            <td class="text-end">

                                <button type="button"
                                        class="btn btn-outline-danger btn-sm eliminar">
                                    Eliminar
                                </button>

                            </td>

                        </tr>`;

                    document.querySelector("#tablaResultados tbody")
                        .insertAdjacentHTML("beforeend", fila);

                    index++;
                });
            }
        });

        document.addEventListener("click", function (e) {

            if (e.target.classList.contains("eliminar")) {

                e.target.closest("[data-resultado-row]").remove();
                reindexarResultados();
            }
        });

    </script>
}
