@model CGA.MetrologySystem.Models.AnularVerificacionViewModel

@{
    ViewData["Title"] = "Anular verificación";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Anular verificación</h2>
        <p class="page-subtitle">
            Invalida este evento sin borrar su trazabilidad metrológica.
        </p>
    </div>

    <a asp-action="Details"
       asp-route-id="@Model.EventoVerificacionDatoId"
       class="btn btn-outline-secondary">
        Cancelar
    </a>
</div>

<form asp-action="Anular"
      asp-route-id="@Model.EventoVerificacionDatoId"
      method="post"
      class="form-card">
    <input asp-for="EventoVerificacionDatoId" type="hidden" />
    <input asp-for="EventoMetrologicoId" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

    <div class="alert alert-warning">
        <strong>Registro conservado.</strong>
        La verificación quedará visible como anulada y dejará de participar en el control metrológico y alertas.
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="text-muted small">Equipo</div>
            <div class="fw-semibold">@Model.CodigoEquipo - @Model.NombreEquipo</div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="text-muted small">Fecha real</div>
            <div class="fw-semibold">@Model.FechaEvento.ToString("yyyy-MM-dd")</div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="text-muted small">Próxima fecha</div>
            <div class="fw-semibold">
                @(Model.FechaProxima.HasValue
                    ? Model.FechaProxima.Value.ToString("yyyy-MM-dd")
                    : "No definida")
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="text-muted small">Responsable</div>
            <div class="fw-semibold">@(Model.ResponsableInterno ?? "No definido")</div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="text-muted small">Subtipo</div>
            <div class="fw-semibold">@(Model.SubtipoEvento ?? "No definido")</div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="text-muted small">Clasificación</div>
            <div class="fw-semibold">@(Model.EsHistorico ? "Histórica" : "Operativa")</div>
        </div>
    </div>

    <div class="mb-4">
        <label asp-for="MotivoAnulacion" class="form-label fw-semibold"></label>
        <textarea asp-for="MotivoAnulacion"
                  class="form-control"
                  rows="3"
                  placeholder="Ejemplo: registro duplicado durante depuración histórica."></textarea>
        <span asp-validation-for="MotivoAnulacion" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Details"
           asp-route-id="@Model.EventoVerificacionDatoId"
           class="btn btn-outline-secondary">
            No anular
        </a>

        <button type="submit" class="btn btn-danger">
            Anular verificación
        </button>
    </div>
</form>
