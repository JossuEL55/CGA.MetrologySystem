@model CGA.MetrologySystem.Models.EquipoViewModel

@{
    ViewData["Title"] = "Editar equipo";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Editar equipo</h2>
        <p class="page-subtitle">
            Actualiza la información general y técnica del equipo seleccionado.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input asp-for="EquipoId" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <h5 class="mb-3">Información general</h5>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="Codigo" class="form-label"></label>
                <input asp-for="Codigo" class="form-control" />
                <span asp-validation-for="Codigo" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3">
                <label asp-for="TipoEquipoId" class="form-label"></label>
                <select asp-for="TipoEquipoId" asp-items="Model.TiposEquipo" class="form-select">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="TipoEquipoId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="ProveedorId" class="form-label"></label>
                <select asp-for="ProveedorId" asp-items="Model.Proveedores" class="form-select">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="ProveedorId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="UbicacionId" class="form-label"></label>
                <select asp-for="UbicacionId" asp-items="Model.Ubicaciones" class="form-select">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="UbicacionId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="ResponsableInternoId" class="form-label"></label>
                <select asp-for="ResponsableInternoId" asp-items="Model.ResponsablesInternos" class="form-select">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="ResponsableInternoId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-check mb-4">
            <input asp-for="Activo" class="form-check-input" type="checkbox" />
            <label asp-for="Activo" class="form-check-label"></label>
        </div>

        <div class="event-upload-box mb-4">
            <div>
                <label asp-for="FotoEquipo" class="form-label fw-semibold mb-1"></label>
                @if (!string.IsNullOrWhiteSpace(Model.FotoActualRutaArchivo))
                {
                    <p class="mb-2">
                        Foto actual:
                        <a href="@Model.FotoActualRutaArchivo" target="_blank">
                            @(Model.FotoActualNombreArchivo ?? "Abrir imagen")
                        </a>
                    </p>
                }
                <p class="mb-0">
                    Carga una nueva imagen para reemplazar la foto actual del equipo.
                </p>
            </div>

            <input asp-for="FotoEquipo"
                   type="file"
                   class="form-control"
                   accept="image/*" />
        </div>
        <span asp-validation-for="FotoEquipo" class="text-danger d-block mb-3"></span>

        <hr />

        <h5 class="mt-4 mb-3">Datos técnicos</h5>

        <div class="row mb-3">
            <div class="col-md-3">
                <label asp-for="Marca" class="form-label"></label>
                <input asp-for="Marca" class="form-control" />
                <span asp-validation-for="Marca" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Modelo" class="form-label"></label>
                <input asp-for="Modelo" class="form-control" />
                <span asp-validation-for="Modelo" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Serie" class="form-label"></label>
                <input asp-for="Serie" class="form-control" />
                <span asp-validation-for="Serie" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Identificacion" class="form-label"></label>
                <input asp-for="Identificacion" class="form-control" />
                <span asp-validation-for="Identificacion" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="FechaAdquisicion" class="form-label"></label>
                <input asp-for="FechaAdquisicion" class="form-control" type="date" />
                <span asp-validation-for="FechaAdquisicion" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="FechaPuestaFuncionamiento" class="form-label"></label>
                <input asp-for="FechaPuestaFuncionamiento" class="form-control" type="date" />
                <span asp-validation-for="FechaPuestaFuncionamiento" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="FabricanteLugarOrigen" class="form-label"></label>
            <input asp-for="FabricanteLugarOrigen" class="form-control" />
            <span asp-validation-for="FabricanteLugarOrigen" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CatalogoManejoOperacion" class="form-label"></label>
            <input asp-for="CatalogoManejoOperacion" class="form-control" />
            <span asp-validation-for="CatalogoManejoOperacion" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MantenimientoFabricante" class="form-label"></label>
            <input asp-for="MantenimientoFabricante" class="form-control" />
            <span asp-validation-for="MantenimientoFabricante" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="CondicionesOperacion" class="form-label"></label>
            <input asp-for="CondicionesOperacion" class="form-control" />
            <span asp-validation-for="CondicionesOperacion" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-primary">
                Guardar cambios
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
