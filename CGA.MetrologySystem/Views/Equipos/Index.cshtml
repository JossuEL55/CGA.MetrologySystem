@model IEnumerable<CGA.MetrologySystem.Domain.Entities.Equipo>

@{
    ViewData["Title"] = "Equipos";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Equipos</h2>
        <p class="page-subtitle">
            Gestiona los equipos registrados y su información técnica principal.
        </p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nuevo equipo</a>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-center">Foto</th>
                    <th>Código</th>
                    <th>Equipo</th>
                    <th>Tipo</th>
                    <th>Proveedor</th>
                    <th>Ubicación</th>
                    <th>Responsable</th>
                    <th>Marca / Modelo</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var equipo in Model)
                    {
                        <tr>
                            <td class="text-center">
                                @if (!string.IsNullOrWhiteSpace(equipo.FotoGoogleDriveFileId))
                                {
                                    <a asp-action="Details" asp-route-id="@equipo.EquipoId" class="equipo-photo-thumb">
                                        <img src="https://drive.google.com/thumbnail?id=@equipo.FotoGoogleDriveFileId&sz=w240"
                                             alt="Foto de @equipo.Codigo" />
                                    </a>
                                }
                                else
                                {
                                    <span class="equipo-photo-thumb equipo-photo-thumb-empty">
                                        Sin foto
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@equipo.Codigo</td>

                            <td>
                                <span class="fw-semibold">@equipo.Nombre</span>
                                <br />
                                <span class="text-muted small">
                                    Serie: @(equipo.Serie ?? "No registrada")
                                </span>
                            </td>

                            <td>@(equipo.TipoEquipo?.Nombre ?? "No registrado")</td>

                            <td>@(equipo.Proveedor?.Nombre ?? "No registrado")</td>

                            <td>@(equipo.Ubicacion?.Nombre ?? "No registrada")</td>

                            <td>@(equipo.ResponsableInterno?.NombreCompleto ?? "No registrado")</td>

                            <td>
                                <span>@(equipo.Marca ?? "No registrada")</span>
                                <br />
                                <span class="text-muted small">
                                    @(equipo.Modelo ?? "Sin modelo")
                                </span>
                            </td>

                            <td>
                                @if (equipo.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2 flex-wrap">
                                    <a asp-action="Edit" asp-route-id="@equipo.EquipoId" class="btn btn-sm btn-outline-primary">
                                        Editar
                                    </a>
                                    <a asp-action="Details" asp-route-id="@equipo.EquipoId" class="btn btn-sm btn-outline-secondary">
                                        Detalles
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@equipo.EquipoId" class="btn btn-sm btn-outline-danger">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">
                            No existen equipos registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
