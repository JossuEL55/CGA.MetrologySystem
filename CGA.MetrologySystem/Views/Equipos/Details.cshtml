@model CGA.MetrologySystem.Domain.Entities.Equipo

@{
    ViewData["Title"] = "Detalles del equipo";
    var puedeGestionar = !User.IsInRole(RolesSistema.AdministradorSistema) && User.IsInRole(RolesSistema.AdministradorMetrologico);
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Detalles del equipo</h2>
        <p class="page-subtitle">
            Consulta la información técnica registrada para este equipo.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="form-card">

    <h5 class="mb-3">Información general</h5>

    <div class="equipo-photo-detail mb-4">
        @if (!string.IsNullOrWhiteSpace(Model.FotoGoogleDriveFileId))
        {
            <a href="@Model.FotoRutaArchivo" target="_blank" class="equipo-photo-frame">
                <img src="https://drive.google.com/thumbnail?id=@Model.FotoGoogleDriveFileId&sz=w1000"
                     alt="Foto de @Model.Codigo" />
            </a>
        }
        else
        {
            <div class="equipo-photo-placeholder">
                Sin foto
            </div>
        }
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Código</label>
            <div class="form-control readonly-highlight">@Model.Codigo</div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Nombre</label>
            <div class="form-control readonly-highlight">@Model.Nombre</div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Tipo de equipo</label>
            <div class="form-control readonly-highlight">
                @(Model.TipoEquipo?.Nombre ?? "No registrado")
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Proveedor</label>
            <div class="form-control readonly-highlight">
                @(Model.Proveedor?.Nombre ?? "No registrado")
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Ubicación</label>
            <div class="form-control readonly-highlight">
                @(Model.Ubicacion?.Nombre ?? "No registrada")
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <label class="form-label">Responsable interno</label>
            <div class="form-control readonly-highlight">
                @(Model.ResponsableInterno?.NombreCompleto ?? "No registrado")
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Estado</label>
            <div>
                @if (Model.Activo)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactivo</span>
                }
            </div>
        </div>
    </div>

    <hr />

    <h5 class="mt-4 mb-3">Datos técnicos</h5>

    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Marca</label>
            <div class="form-control readonly-highlight">
                @(Model.Marca ?? "No registrada")
            </div>
        </div>

        <div class="col-md-3">
            <label class="form-label">Modelo</label>
            <div class="form-control readonly-highlight">
                @(Model.Modelo ?? "No registrado")
            </div>
        </div>

        <div class="col-md-3">
            <label class="form-label">Serie</label>
            <div class="form-control readonly-highlight">
                @(Model.Serie ?? "No registrada")
            </div>
        </div>

        <div class="col-md-3">
            <label class="form-label">Identificación</label>
            <div class="form-control readonly-highlight">
                @(Model.Identificacion ?? "No registrada")
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Fecha de adquisición</label>
            <div class="form-control readonly-highlight">
                @(Model.FechaAdquisicion?.ToString("yyyy-MM-dd") ?? "No registrada")
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Fecha de puesta en funcionamiento</label>
            <div class="form-control readonly-highlight">
                @(Model.FechaPuestaFuncionamiento?.ToString("yyyy-MM-dd") ?? "No registrada")
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Fabricante / Lugar de origen</label>
        <div class="form-control readonly-highlight">
            @(Model.FabricanteLugarOrigen ?? "No registrado")
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Catálogo de manejo u operación</label>
        <div class="form-control readonly-highlight">
            @(Model.CatalogoManejoOperacion ?? "No registrado")
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Mantenimiento indicado por el fabricante</label>
        <div class="form-control readonly-highlight">
            @(Model.MantenimientoFabricante ?? "No registrado")
        </div>
    </div>

    <div class="mb-4">
        <label class="form-label">Condiciones de operación</label>
        <div class="form-control readonly-highlight">
            @(Model.CondicionesOperacion ?? "No registrado")
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        @if (puedeGestionar)
        {
            <a asp-action="Edit" asp-route-id="@Model.EquipoId" class="btn btn-primary">
                Editar
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>

</div>
