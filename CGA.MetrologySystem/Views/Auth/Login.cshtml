@model CGA.MetrologySystem.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_LayoutAuth";
}

<div class="auth-form-wrapper">
    <div class="auth-form-header">
        <span class="auth-form-eyebrow">Acceso seguro</span>
        <h2 class="auth-form-title">Bienvenido</h2>
        <p class="auth-form-subtitle">Accede con tu cuenta corporativa.</p>
    </div>

    <form asp-action="Login" method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

        <div class="auth-field">
            <label asp-for="Correo" class="auth-label"></label>
            <div class="auth-input-group">
                <span class="auth-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M4.75 6.75h14.5v10.5H4.75z" />
                        <path d="m5.25 7.25 6.75 5.5 6.75-5.5" />
                    </svg>
                </span>
                <input asp-for="Correo"
                       class="form-control auth-input"
                       placeholder="usuario@cga.com.ec"
                       autofocus />
            </div>
            <span asp-validation-for="Correo" class="text-danger"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Contrasena" class="auth-label"></label>
            <div class="auth-input-group">
                <span class="auth-input-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7.75 10.25V8a4.25 4.25 0 0 1 8.5 0v2.25" />
                        <path d="M6.75 10.25h10.5a1.5 1.5 0 0 1 1.5 1.5v5.5a1.5 1.5 0 0 1-1.5 1.5H6.75a1.5 1.5 0 0 1-1.5-1.5v-5.5a1.5 1.5 0 0 1 1.5-1.5Z" />
                    </svg>
                </span>
                <input asp-for="Contrasena"
                       type="password"
                       class="form-control auth-input auth-password-input"
                       placeholder="Ingresa tu contraseña" />
                <button type="button"
                        class="auth-password-toggle"
                        aria-label="Mostrar contraseña"
                        aria-pressed="false">
                    <svg class="auth-eye-open" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="M2.75 12s3.25-5.25 9.25-5.25S21.25 12 21.25 12 18 17.25 12 17.25 2.75 12 2.75 12Z" />
                        <path d="M12 9.25A2.75 2.75 0 1 1 12 14.75 2.75 2.75 0 0 1 12 9.25Z" />
                    </svg>
                    <svg class="auth-eye-closed" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="m4 4 16 16" />
                        <path d="M9.4 6.95A9.37 9.37 0 0 1 12 6.75c6 0 9.25 5.25 9.25 5.25a15.67 15.67 0 0 1-3.04 3.36" />
                        <path d="M14.15 14.15A2.75 2.75 0 0 1 9.85 9.85" />
                        <path d="M6.12 8.48A15.29 15.29 0 0 0 2.75 12S6 17.25 12 17.25a9.51 9.51 0 0 0 3.18-.53" />
                    </svg>
                </button>
            </div>
            <span asp-validation-for="Contrasena" class="text-danger"></span>
        </div>

        <div class="form-check auth-remember">
            <input asp-for="Recordarme" class="form-check-input" />
            <label asp-for="Recordarme" class="form-check-label"></label>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg auth-submit">
                Ingresar
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const toggle = document.querySelector('.auth-password-toggle');
            const input = document.querySelector('.auth-password-input');

            if (!toggle || !input) {
                return;
            }

            toggle.addEventListener('click', () => {
                const mostrar = input.type === 'password';
                input.type = mostrar ? 'text' : 'password';
                toggle.setAttribute('aria-pressed', mostrar.toString());
                toggle.setAttribute('aria-label', mostrar ? 'Ocultar contraseña' : 'Mostrar contraseña');
            });
        })();
    </script>
}
