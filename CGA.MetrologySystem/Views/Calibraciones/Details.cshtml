@model CGA.MetrologySystem.Domain.Entities.EventoCalibracionDato

@{
    ViewData["Title"] = "Detalle de calibración";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Detalle de calibración</h2>
        <p class="page-subtitle">
            Consulta la información del evento metrológico y el certificado asociado.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="form-card">
    <h5 class="mb-3">Información del equipo</h5>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Equipo</label>
            <div class="form-control readonly-highlight">
                @Model.EventoMetrologico?.Equipo?.Codigo - @Model.EventoMetrologico?.Equipo?.Nombre
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Subtipo</label>
            <div class="form-control readonly-highlight">
                @(Model.EventoMetrologico?.SubtipoEvento?.Nombre ?? "No registrado")
            </div>
        </div>
    </div>

    <h5 class="mt-4 mb-3">Información del evento</h5>

    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Responsable interno</label>
            <div class="form-control readonly-highlight">
                @(Model.EventoMetrologico?.ResponsableInterno?.NombreCompleto ?? "No registrado")
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Fecha evento</label>
            <div class="form-control readonly-highlight">
                @(Model.EventoMetrologico?.FechaEvento.ToString("yyyy-MM-dd") ?? "No registrada")
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Próxima fecha</label>
            <div class="form-control readonly-highlight">
                @(Model.EventoMetrologico?.FechaProxima?.ToString("yyyy-MM-dd") ?? "No registrada")
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Estado del equipo</label>
            <div>
                @if (!string.IsNullOrWhiteSpace(Model.EventoMetrologico?.EstadoEquipoResultado))
                {
                    <span class="badge bg-success">@Model.EventoMetrologico.EstadoEquipoResultado</span>
                }
                else
                {
                    <span class="badge bg-secondary">No registrado</span>
                }
            </div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Evento extraordinario</label>
            <div>
                @if (Model.EventoMetrologico?.EsExtraordinario == true)
                {
                    <span class="badge bg-warning text-dark">Sí</span>
                }
                else
                {
                    <span class="badge bg-secondary">No</span>
                }
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Comentarios adicionales</label>
        <div class="form-control readonly-highlight">
            @(Model.EventoMetrologico?.ComentariosAdicionales ?? "Sin comentarios")
        </div>
    </div>

    <div class="mb-4">
        <label class="form-label">Justificación extraordinaria</label>
        <div class="form-control readonly-highlight">
            @(Model.EventoMetrologico?.JustificacionExtraordinario ?? "No aplica")
        </div>
    </div>

    <h5 class="mt-4 mb-3">Información de calibración</h5>

    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Número certificado</label>
            <div class="form-control readonly-highlight">
                @(Model.NumeroCertificado ?? "No registrado")
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Fecha calibración</label>
            <div class="form-control readonly-highlight">
                @(Model.FechaCalibracion?.ToString("yyyy-MM-dd") ?? "No registrada")
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Laboratorio</label>
            <div class="form-control readonly-highlight">
                @(Model.Laboratorio?.Nombre ?? "No registrado")
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Observaciones</label>
        <div class="form-control readonly-highlight">
            @(Model.Observaciones ?? "Sin observaciones")
        </div>
    </div>

    <div class="mb-4">
        <label class="form-label">Archivo PDF</label>
        <div>
            @if (!string.IsNullOrWhiteSpace(Model.RutaCertificado))
            {
                <a href="@Model.RutaCertificado" target="_blank" class="btn btn-sm btn-outline-success">
                    Ver certificado
                </a>
            }
            else
            {
                <span class="badge bg-secondary">Sin archivo</span>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Edit" asp-route-id="@Model.EventoCalibracionDatoId" class="btn btn-primary">
            Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>
</div>