@model IEnumerable<CGA.MetrologySystem.Domain.Entities.EventoCalibracionDato>

@{
    ViewData["Title"] = "Calibraciones";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Calibraciones</h2>
        <p class="page-subtitle">
            Consulta el historial de calibraciones, certificados cargados y próximas fechas de control.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        + Registrar calibración
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="event-index-card">
    <div class="event-index-header">
        <div>
            <span class="section-kicker">Historial metrológico</span>
            <h5 class="mb-1">Registros de calibración</h5>
            <p class="page-subtitle">
                Visualiza certificados, laboratorios, responsables y estado operativo de cada equipo.
            </p>
        </div>

        <div class="event-count-pill">
            @Model.Count() registro(s)
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="event-empty-state">
            <div class="event-empty-icon">C</div>
            <h5>Aún no hay calibraciones registradas</h5>
            <p>
                Cuando registres una calibración, aparecerá aquí con su certificado, laboratorio y próxima fecha calculada.
            </p>
            <a asp-action="Create" class="btn btn-primary">
                Registrar primera calibración
            </a>
        </div>
    }
    else
    {
        <div class="event-table-wrapper">
            <table class="table event-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Equipo</th>
                        <th>Certificado</th>
                        <th>Fechas</th>
                        <th>Laboratorio</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th class="text-center">Documento</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var evento = item.EventoMetrologico;
                        var estado = evento.EstadoEquipoResultado ?? "Sin estado";

                        var badgeClass = estado switch
                        {
                            "Operativo" => "event-badge event-badge-success",
                            "No Operativo" => "event-badge event-badge-danger",
                            "Fuera de Servicio" => "event-badge event-badge-dark",
                            _ => "event-badge event-badge-muted"
                        };

                        <tr>
                            <td class="event-equipment-cell">
                                <div class="event-code">@evento.Equipo?.Codigo</div>
                                <div class="event-name">@evento.Equipo?.Nombre</div>
                            </td>

                            <td>
                                <div class="event-main-text">
                                    @(string.IsNullOrWhiteSpace(item.NumeroCertificado)
                                        ? "Sin número"
                                        : item.NumeroCertificado)
                                </div>
                                <div class="event-secondary-text">
                                    Calibración:
                                    @(item.FechaCalibracion.HasValue
                                        ? item.FechaCalibracion.Value.ToString("yyyy-MM-dd")
                                        : "No definida")
                                </div>
                            </td>

                            <td>
                                <div class="event-date-stack">
                                    <div>
                                        <span>Evento</span>
                                        <strong>@evento.FechaEvento.ToString("yyyy-MM-dd")</strong>
                                    </div>

                                    <div>
                                        <span>Próxima</span>
                                        <strong>
                                            @(evento.FechaProxima.HasValue
                                                ? evento.FechaProxima.Value.ToString("yyyy-MM-dd")
                                                : "No definida")
                                        </strong>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="event-main-text">
                                    @(item.Laboratorio?.Nombre ?? "No definido")
                                </div>
                            </td>

                            <td>
                                <div class="event-main-text">
                                    @(evento.ResponsableInterno?.NombreCompleto ?? "No definido")
                                </div>
                            </td>

                            <td>
                                <div class="d-flex flex-column align-items-start gap-1">
                                    <span class="@badgeClass">@estado</span>

                                    @if (evento.EsExtraordinario)
                                    {
                                        <span class="event-badge event-badge-warning">
                                            Extraordinaria
                                        </span>
                                    }
                                </div>
                            </td>

                            <td class="text-center">
                                @if (!string.IsNullOrWhiteSpace(item.RutaCertificado))
                                {
                                    <a href="@item.RutaCertificado"
                                       target="_blank"
                                       class="btn btn-outline-primary btn-sm event-document-button">
                                        Ver PDF
                                    </a>
                                }
                                else
                                {
                                    <span class="event-file-muted">Sin archivo</span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="event-actions">
                                    <a asp-action="Details"
                                       asp-route-id="@item.EventoCalibracionDatoId"
                                       class="btn btn-outline-secondary btn-sm">
                                        Detalle
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.EventoCalibracionDatoId"
                                       class="btn btn-outline-primary btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.EventoCalibracionDatoId"
                                       class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>