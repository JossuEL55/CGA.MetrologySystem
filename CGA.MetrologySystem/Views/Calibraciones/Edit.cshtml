@model CGA.MetrologySystem.Models.CalibracionViewModel

@{
    ViewData["Title"] = "Editar calibración";

    var eventoCalibracionDatoId = ViewBag.EventoCalibracionDatoId;
    var nombreArchivoCertificado = ViewBag.NombreArchivoCertificado as string;
    var rutaCertificado = ViewBag.RutaCertificado as string;
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Editar calibración</h2>
        <p class="page-subtitle">
            Actualiza los datos de calibración. Si cargas un nuevo certificado, el anterior será reemplazado en el repositorio documental.
        </p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@eventoCalibracionDatoId" class="btn btn-outline-primary">
            Ver detalle
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>
</div>

@if (TempData["AdvertenciaRegla"] != null)
{
    <div class="alert alert-warning">
        @TempData["AdvertenciaRegla"]
    </div>
}

<form asp-action="Edit" asp-route-id="@eventoCalibracionDatoId" method="post" enctype="multipart/form-data" class="form-card">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

    <div class="mb-4">
        <h5 class="mb-1">Información del evento metrológico</h5>
        <p class="text-muted mb-0">
            El motor de reglas recalculará la próxima fecha cuando guardes los cambios.
        </p>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="EquipoId" class="form-label fw-semibold">Equipo</label>
            <select asp-for="EquipoId" asp-items="Model.Equipos" class="form-select">
                <option value="">Seleccione un equipo...</option>
            </select>
            <span asp-validation-for="EquipoId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="SubtipoEventoId" class="form-label fw-semibold">Subtipo de evento</label>
            <select asp-for="SubtipoEventoId" asp-items="Model.SubtiposEvento" class="form-select">
                <option value="">Seleccione un subtipo...</option>
            </select>
            <span asp-validation-for="SubtipoEventoId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ResponsableInternoId" class="form-label fw-semibold">Responsable interno</label>
            <select asp-for="ResponsableInternoId" asp-items="Model.ResponsablesInternos" class="form-select">
                <option value="">Seleccione un responsable...</option>
            </select>
            <span asp-validation-for="ResponsableInternoId" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="FechaEvento" class="form-label fw-semibold">Fecha del evento</label>
            <input asp-for="FechaEvento" class="form-control" type="date" />
            <span asp-validation-for="FechaEvento" class="text-danger"></span>
        </div>

        <div class="col-md-3 mb-3">
            <label asp-for="FechaProxima" class="form-label fw-semibold">Próxima fecha calculada</label>
            <input asp-for="FechaProxima"
                   class="form-control bg-light"
                   type="date"
                   readonly
                   tabindex="-1" />
            <span asp-validation-for="FechaProxima" class="text-danger"></span>
        </div>
    </div>

    <div class="alert alert-light border mb-4">
        <strong>Nota:</strong> si modificas la fecha del evento, el sistema volverá a evaluar si la calibración es ordinaria o extraordinaria.
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="EstadoEquipoResultado" class="form-label fw-semibold">Estado del equipo</label>
            <select asp-for="EstadoEquipoResultado" class="form-select">
                <option value="">Seleccione...</option>
                <option value="Operativo">Operativo</option>
                <option value="No Operativo">No Operativo</option>
                <option value="Fuera de Servicio">Fuera de Servicio</option>
            </select>
            <span asp-validation-for="EstadoEquipoResultado" class="text-danger"></span>
        </div>

        <div class="col-md-8 mb-3">
            <label asp-for="JustificacionExtraordinario" class="form-label fw-semibold">
                Justificación extraordinaria
            </label>
            <textarea asp-for="JustificacionExtraordinario"
                      class="form-control"
                      rows="2"
                      placeholder="Completa este campo si la calibración fue extraordinaria."></textarea>
            <span asp-validation-for="JustificacionExtraordinario" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-4">
        <label asp-for="ComentariosAdicionales" class="form-label fw-semibold">Comentarios adicionales</label>
        <textarea asp-for="ComentariosAdicionales"
                  class="form-control"
                  rows="3"
                  placeholder="Comentarios generales del evento."></textarea>
        <span asp-validation-for="ComentariosAdicionales" class="text-danger"></span>
    </div>

    <hr class="my-4" />

    <div class="mb-4">
        <h5 class="mb-1">Datos del certificado</h5>
        <p class="text-muted mb-0">
            Actualiza los datos del documento emitido por el laboratorio externo.
        </p>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="NumeroCertificado" class="form-label fw-semibold">Número de certificado</label>
            <input asp-for="NumeroCertificado" class="form-control" />
            <span asp-validation-for="NumeroCertificado" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="FechaCalibracion" class="form-label fw-semibold">Fecha de calibración</label>
            <input asp-for="FechaCalibracion" class="form-control" type="date" />
            <span asp-validation-for="FechaCalibracion" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="LaboratorioId" class="form-label fw-semibold">Laboratorio</label>
            <select asp-for="LaboratorioId" asp-items="Model.Laboratorios" class="form-select">
                <option value="">Seleccione un laboratorio...</option>
            </select>
            <span asp-validation-for="LaboratorioId" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Observaciones" class="form-label fw-semibold">Observaciones del certificado</label>
        <textarea asp-for="Observaciones"
                  class="form-control"
                  rows="3"
                  placeholder="Observaciones propias del certificado o del laboratorio."></textarea>
        <span asp-validation-for="Observaciones" class="text-danger"></span>
    </div>

    <div class="border rounded p-3 mb-3 bg-light">
        <div class="fw-semibold mb-1">Certificado actual</div>

        @if (!string.IsNullOrWhiteSpace(rutaCertificado))
        {
            <div class="text-muted small mb-2 text-break">
                @nombreArchivoCertificado
            </div>

            <a asp-controller="Documentos"
               asp-action="VerPdf"
               asp-route-tipo="calibracion"
               asp-route-id="@ViewBag.EventoCalibracionDatoId"
               class="btn btn-outline-primary btn-sm">
                Ver certificado actual
            </a>
        }
        else
        {
            <span class="text-muted">No existe certificado asociado.</span>
        }
    </div>

    <div class="mb-4">
        <label asp-for="ArchivoCertificado" class="form-label fw-semibold">Reemplazar certificado PDF</label>
        <input asp-for="ArchivoCertificado"
               class="form-control"
               type="file"
               accept="application/pdf,.pdf" />
        <span asp-validation-for="ArchivoCertificado" class="text-danger"></span>
        <small class="text-muted">
            Si seleccionas un nuevo PDF, el certificado anterior será reemplazado por este archivo.
        </small>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Details" asp-route-id="@eventoCalibracionDatoId" class="btn btn-outline-secondary">
            Cancelar
        </a>
        <button type="submit" class="btn btn-primary">
            Guardar cambios
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
