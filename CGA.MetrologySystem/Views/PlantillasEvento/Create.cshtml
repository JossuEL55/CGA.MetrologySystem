@model CGA.MetrologySystem.Models.PlantillaEventoViewModel

@{
    ViewData["Title"] = "Crear plantilla";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Crear plantilla</h2>
        <p class="page-subtitle">Define una nueva plantilla para eventos metrológicos.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<form asp-action="Create" class="form-card">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Tipo equipo</label>
            <select asp-for="TipoEquipoId" asp-items="Model.TiposEquipo" class="form-control"></select>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Tipo evento</label>
            <select asp-for="TipoEventoMetrologicoId" asp-items="Model.TiposEventoMetrologico" class="form-control"></select>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Nombre</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
    </div>

    <div class="form-check mb-4">
        <input asp-for="Activo" class="form-check-input" />
        <label class="form-check-label fw-semibold">Activo</label>
    </div>

    <hr />
    <h5 class="mb-3">Items de la plantilla</h5>

    <table class="table" id="tablaItems">
        <tbody>
            @for (int i = 0; i < Model.Items.Count; i++)
            {
                <tr>
                    <td>
                        <input asp-for="Items[i].Descripcion" class="form-control" placeholder="Descripción del ítem" />
                    </td>
                    <td style="width:120px;">
                        <input asp-for="Items[i].Activo" class="form-check-input" />
                    </td>
                    <td style="width:80px;">
                        <button type="button" class="btn btn-outline-danger eliminar">X</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="button" id="addItem" class="btn btn-outline-secondary mb-4">Agregar ítem</button>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">Guardar</button>
    </div>
</form>

@section Scripts {
    <script>
        let index = @Model.Items.Count;

        document.getElementById("addItem").addEventListener("click", function () {
            let fila = `
            <tr>
                <td><input name="Items[${index}].Descripcion" class="form-control"/></td>
                <td class="align-middle">
                 <input type="checkbox" name="Items[${index}].Activo" value="true" checked class="form-check-input" />
                  <input type="hidden" name="Items[${index}].Activo" value="false" />
                </td>   
                <td><button type="button" class="btn btn-outline-danger eliminar">X</button></td>
            </tr>`;
            document.querySelector("#tablaItems tbody").insertAdjacentHTML("beforeend", fila);
            index++;
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("eliminar")) {
                e.target.closest("tr").remove();
            }
        });
    </script>
}