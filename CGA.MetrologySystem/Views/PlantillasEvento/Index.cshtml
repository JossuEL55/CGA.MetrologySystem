@model IEnumerable<CGA.MetrologySystem.Domain.Entities.PlantillaEvento>

@{
    ViewData["Title"] = "Plantillas de evento";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Plantillas de evento</h2>
        <p class="page-subtitle">
            Administra las plantillas que se usarán para generar verificaciones y mantenimientos.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Nueva plantilla
    </a>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Tipo de equipo</th>
                    <th>Tipo de evento</th>
                    <th>Nombre</th>
                    <th>Ítems</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No existen plantillas de evento registradas.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TipoEquipo?.Nombre</td>
                            <td>@item.TipoEventoMetrologico?.Nombre</td>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    @(item.Items?.Count ?? 0) ítems
                                </span>
                            </td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="section-actions justify-content-end">
                                    <a asp-action="Details"
                                           asp-route-id="@item.PlantillaEventoId"
                                           class="btn btn-outline-info btn-sm">
                                        Ver
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.PlantillaEventoId"
                                           class="btn btn-outline-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.PlantillaEventoId"
                                           class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>