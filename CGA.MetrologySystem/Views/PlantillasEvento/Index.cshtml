@model IEnumerable<CGA.MetrologySystem.Domain.Entities.PlantillaEvento>

@{
    ViewData["Title"] = "Plantillas de evento";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Plantillas de evento</h2>
        <p class="page-subtitle">Gestiona las plantillas para mantenimiento y verificación.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nueva plantilla</a>
</div>

<div class="form-card">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Tipo equipo</th>
                <th>Tipo evento</th>
                <th>Nombre</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TipoEquipo?.Nombre</td>
                    <td>@item.TipoEventoMetrologico?.Nombre</td>
                    <td>@item.Nombre</td>
                    <td>
                        <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                            @(item.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.PlantillaEventoId" class="btn btn-outline-info btn-sm">Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.PlantillaEventoId" class="btn btn-outline-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.PlantillaEventoId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>