@model CGA.MetrologySystem.Domain.Entities.PlantillaEvento

@{
    ViewData["Title"] = "Eliminar plantilla";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Eliminar plantilla</h2>
        <p class="page-subtitle">
            Confirma la eliminación de la plantilla seleccionada.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="form-card">
    <div class="alert alert-danger">
        ¿Estás seguro de que deseas eliminar esta plantilla? Esta acción no se puede deshacer.
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Nombre</label>
        <input class="form-control readonly-highlight" value="@Model.Nombre" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Tipo equipo</label>
        <input class="form-control readonly-highlight" value="@Model.TipoEquipo?.Nombre" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Tipo evento</label>
        <input class="form-control readonly-highlight" value="@Model.TipoEventoMetrologico?.Nombre" readonly />
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        <input type="hidden" asp-for="PlantillaEventoId" />
        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-danger">Eliminar</button>
        </div>
    </form>
</div>