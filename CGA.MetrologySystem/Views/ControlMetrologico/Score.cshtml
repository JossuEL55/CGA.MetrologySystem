@model CGA.MetrologySystem.Models.ControlMetrologico.ControlMetrologicoScoreViewModel

@{
    ViewData["Title"] = "Score metrológico";
}

<div class="metro-hero mb-4">
    <div>
        <span class="metro-eyebrow">
            <i class="bi bi-speedometer2"></i> Priorización técnica
        </span>

        <h1>Score metrológico</h1>

        <p>
            Índice de prioridad metrológica basado en vencimiento, proximidad,
            información incompleta y antecedentes de eventos extraordinarios.
        </p>
    </div>

    <div class="metro-hero-actions d-flex gap-2">
        <a asp-action="Index" class="btn btn-light">
            <i class="bi bi-grid-3x3-gap"></i> Vista por equipo
        </a>

        <a asp-action="Eventos" class="btn btn-light">
            <i class="bi bi-list-check"></i> Vista por evento
        </a>
    </div>
</div>

<div class="metro-summary-grid score-summary-grid mb-4">
    <div class="metro-kpi">
        <span>Controles evaluados</span>
        <strong>@Model.ResumenScore.TotalControlesEvaluados</strong>
        <i class="bi bi-ui-checks-grid"></i>
    </div>

    <div class="metro-kpi kpi-danger">
        <span>Críticos</span>
        <strong>@Model.ResumenScore.ControlesCriticos</strong>
        <i class="bi bi-exclamation-octagon-fill"></i>
    </div>

    <div class="metro-kpi kpi-warning">
        <span>Prioridad alta</span>
        <strong>@Model.ResumenScore.ControlesAltaPrioridad</strong>
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <div class="metro-kpi kpi-ok">
        <span>Promedio score</span>
        <strong>@Model.ResumenScore.PromedioScore.ToString("0.0")</strong>
        <i class="bi bi-graph-up-arrow"></i>
    </div>

    <div class="metro-kpi kpi-config score-kpi-wide">
        <span>Mayor score</span>
        <strong>@Model.ResumenScore.MayorScore</strong>
        <small>@Model.ResumenScore.EquipoMayorScore</small>
        <i class="bi bi-trophy-fill"></i>
    </div>
</div>

<div class="metro-filter-card mb-4">
    <form asp-action="Score" method="get" class="row g-3 align-items-end">
        <div class="col-lg-3 col-md-6">
            <label class="form-label">Buscar equipo</label>
            <div class="metro-input-icon">
                <i class="bi bi-search"></i>
                <input name="buscar"
                       value="@Model.Filtros.Buscar"
                       class="form-control"
                       placeholder="Código o nombre del equipo" />
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <label class="form-label">Tipo de equipo</label>
            <select name="tipoEquipoId" class="form-select" asp-items="Model.Filtros.TiposEquipo">
                <option value="">Todos</option>
            </select>
        </div>

        <div class="col-lg-2 col-md-6">
            <label class="form-label">Tipo de evento</label>
            <select name="tipoEventoMetrologicoId" class="form-select" asp-items="Model.Filtros.TiposEvento">
                <option value="">Todos</option>
            </select>
        </div>

        <div class="col-lg-2 col-md-6">
            <label class="form-label">Estado</label>
            <select name="estado" class="form-select" asp-items="Model.Filtros.Estados">
                <option value="">Todos</option>
            </select>
        </div>

        <div class="col-lg-1 col-md-6">
            <label class="form-label">Horizonte</label>
            <select name="horizonteDias" class="form-select" asp-items="Model.Filtros.Horizontes"></select>
        </div>

        <div class="col-lg-2 col-md-6 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 metro-btn-main">
                <i class="bi bi-funnel"></i> Filtrar
            </button>

            <a asp-action="LimpiarFiltrosScore" class="btn btn-outline-secondary metro-btn-icon" title="Limpiar filtros">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </form>
</div>

<div class="metro-table-card">
    <div class="metro-table-header">
        <div>
            <h5>Prioridad de controles</h5>
            <p>Controles ordenados de mayor a menor score metrológico.</p>
        </div>

        <span class="metro-table-count">
            @Model.Items.Count control(es)
        </span>
    </div>

    <div class="table-responsive">
        <table class="table metro-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Equipo</th>
                    <th>Tipo equipo</th>
                    <th>Tipo de control</th>
                    <th>Estado</th>
                    <th>Último evento</th>
                    <th>Próxima fecha</th>
                    <th>Días</th>
                    <th>Extraordinarios</th>
                    <th>Score</th>
                    <th>Prioridad</th>
                    <th>Explicación</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center py-5">
                            <div class="metro-empty">
                                <i class="bi bi-speedometer"></i>
                                <h5>No se encontraron controles</h5>
                                <p>No existen resultados para los filtros aplicados.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="metro-equipo-cell">
                                    <div class="metro-equipo-avatar">
                                        <i class="bi bi-tools"></i>
                                    </div>

                                    <div>
                                        <strong>@item.CodigoEquipo</strong>
                                        <span>@item.NombreEquipo</span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="metro-type-pill">@item.TipoEquipo</span>
                            </td>

                            <td>
                                <div class="metro-event-pill">
                                    <i class="bi @item.IconoEstado"></i>
                                    <span>@item.TipoEventoNombre</span>
                                </div>
                            </td>

                            <td>
                                <span class="metro-status-pill @item.CssEstado">
                                    <i class="bi @item.IconoEstado"></i>
                                    @item.EstadoTexto
                                </span>
                            </td>

                            <td>
                                <span class="metro-date-text">
                                    @(item.FechaUltimoEvento.HasValue
                                        ? item.FechaUltimoEvento.Value.ToString("yyyy-MM-dd")
                                        : "N/D")
                                </span>
                            </td>

                            <td>
                                <span class="metro-date-text">
                                    @(item.FechaProxima.HasValue
                                        ? item.FechaProxima.Value.ToString("yyyy-MM-dd")
                                        : "N/D")
                                </span>
                            </td>

                            <td>
                                @if (item.DiasRestantes.HasValue)
                                {
                                    <span class="metro-days-pill @item.CssEstado">
                                        @item.DiasRestantes día(s)
                                    </span>
                                }
                                else
                                {
                                    <span class="metro-days-pill estado-sin-eventos">
                                        N/D
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="metro-extra-pill">
                                    @item.CantidadEventosExtraordinarios
                                </span>
                            </td>

                            <td>
                                <div class="metro-score-value">
                                    <strong>@item.ScoreMetrologico</strong>
                                    <span>/100</span>
                                </div>
                            </td>

                            <td>
                                <span class="metro-priority-pill @item.CssPrioridad">
                                    @item.NivelPrioridad
                                </span>
                            </td>

                            <td>
                                <span class="metro-message-text">
                                    @item.ExplicacionScore
                                </span>
                            </td>

                            <td class="text-end">
                                <a asp-controller="Equipos"
                                   asp-action="Details"
                                   asp-route-id="@item.EquipoId"
                                   class="btn btn-sm btn-outline-primary metro-action-btn">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
