@model CGA.MetrologySystem.Models.ControlMetrologico.ControlMetrologicoEventosViewModel

@{
    ViewData["Title"] = "Eventos metrológicos";
}

<div class="metro-hero mb-4">
    <div>
        <span class="metro-eyebrow">
            <i class="bi bi-list-check"></i> Planificación operativa
        </span>

        <h1>Eventos metrológicos</h1>

        <p>
            Vista detallada por control técnico para identificar calibraciones, verificaciones
            y mantenimientos vencidos, próximos o pendientes de configuración.
        </p>
    </div>

    <div class="metro-hero-actions">
        @if (User.IsInRole("Administrador"))
        {
            <form asp-controller="Alertas" asp-action="Procesar" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-envelope-paper"></i> Procesar alertas
                </button>
            </form>
        }

        <a asp-action="Index" class="btn btn-light">
            <i class="bi bi-grid-3x3-gap"></i> Vista por equipo
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="metro-summary-grid mb-4">
    <div class="metro-kpi">
        <span>Equipos filtrados</span>
        <strong>@Model.Resumen.TotalEquipos</strong>
        <i class="bi bi-box-seam"></i>
    </div>

    <div class="metro-kpi kpi-ok">
        <span>Vigentes</span>
        <strong>@Model.Resumen.Vigentes</strong>
        <i class="bi bi-check-circle-fill"></i>
    </div>

    <div class="metro-kpi kpi-warning">
        <span>Próximos</span>
        <strong>@Model.Resumen.ProximosAVencer</strong>
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <div class="metro-kpi kpi-danger">
        <span>Vencidos</span>
        <strong>@Model.Resumen.Vencidos</strong>
        <i class="bi bi-x-circle-fill"></i>
    </div>

    <div class="metro-kpi kpi-muted">
        <span>Sin eventos</span>
        <strong>@Model.Resumen.SinEventos</strong>
        <i class="bi bi-calendar-x"></i>
    </div>

    <div class="metro-kpi kpi-config">
        <span>Sin configuración</span>
        <strong>@Model.Resumen.SinConfiguracion</strong>
        <i class="bi bi-gear-fill"></i>
    </div>
</div>

<div class="metro-filter-card mb-4">
    <form asp-action="Eventos" method="get" class="row g-3 align-items-end">
        <div class="col-lg-3 col-md-6">
            <label class="form-label">Buscar equipo</label>
            <div class="metro-input-icon">
                <i class="bi bi-search"></i>
                <input name="buscar"
                       value="@Model.Filtros.Buscar"
                       class="form-control"
                       placeholder="Código o nombre del equipo" />
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <label class="form-label">Tipo de equipo</label>
            <select name="tipoEquipoId" class="form-select" asp-items="Model.Filtros.TiposEquipo">
                <option value="">Todos</option>
            </select>
        </div>

        <div class="col-lg-2 col-md-6">
            <label class="form-label">Tipo de evento</label>
            <select name="tipoEventoMetrologicoId" class="form-select" asp-items="Model.Filtros.TiposEvento">
                <option value="">Todos</option>
            </select>
        </div>

        <div class="col-lg-2 col-md-6">
            <label class="form-label">Estado</label>
            <select name="estado" class="form-select" asp-items="Model.Filtros.Estados">
                <option value="">Todos</option>
            </select>
        </div>

        <div class="col-lg-1 col-md-6">
            <label class="form-label">Horizonte</label>
            <select name="horizonteDias" class="form-select" asp-items="Model.Filtros.Horizontes"></select>
        </div>

        <div class="col-lg-2 col-md-6 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100 metro-btn-main">
                <i class="bi bi-funnel"></i> Filtrar
            </button>

            <a asp-action="LimpiarFiltrosEventos" class="btn btn-outline-secondary metro-btn-icon" title="Limpiar filtros">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </form>
</div>

<div class="metro-table-card">
    <div class="metro-table-header">
        <div>
            <h5>Agenda operativa de controles</h5>
            <p>Listado individual de cada control metrológico asociado a los equipos activos.</p>
        </div>

        <span class="metro-table-count">
            @Model.Eventos.Count evento(s)
        </span>
    </div>

    <div class="table-responsive">
        <table class="table metro-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Equipo</th>
                    <th>Tipo equipo</th>
                    <th>Evento</th>
                    <th>Estado</th>
                    <th>Último evento</th>
                    <th>Próxima fecha</th>
                    <th>Días</th>
                    <th>Mensaje</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Eventos.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center py-5">
                            <div class="metro-empty">
                                <i class="bi bi-calendar2-x"></i>
                                <h5>No se encontraron eventos</h5>
                                <p>No existen controles metrológicos para los filtros aplicados.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var evento in Model.Eventos)
                    {
                        <tr>
                            <td>
                                <div class="metro-equipo-cell">
                                    <div class="metro-equipo-avatar">
                                        <i class="bi bi-tools"></i>
                                    </div>

                                    <div>
                                        <strong>@evento.CodigoEquipo</strong>
                                        <span>@evento.NombreEquipo</span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="metro-type-pill">@evento.TipoEquipo</span>
                            </td>

                            <td>
                                <div class="metro-event-pill">
                                    <i class="bi @evento.Icono"></i>
                                    <span>@evento.TipoEventoNombre</span>
                                </div>
                            </td>

                            <td>
                                <span class="metro-status-pill @evento.CssClass">
                                    <i class="bi @evento.Icono"></i>
                                    @evento.Estado
                                </span>
                            </td>

                            <td>
                                <span class="metro-date-text">
                                    @(evento.FechaUltimoEvento.HasValue
                                        ? evento.FechaUltimoEvento.Value.ToString("yyyy-MM-dd")
                                        : "N/D")
                                </span>
                            </td>

                            <td>
                                <span class="metro-date-text">
                                    @(evento.FechaProxima.HasValue
                                        ? evento.FechaProxima.Value.ToString("yyyy-MM-dd")
                                        : "N/D")
                                </span>
                            </td>

                            <td>
                                @if (evento.DiasRestantes.HasValue)
                                {
                                    <span class="metro-days-pill @evento.CssClass">
                                        @evento.DiasRestantes día(s)
                                    </span>
                                }
                                else
                                {
                                    <span class="metro-days-pill estado-sin-eventos">
                                        N/D
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="metro-message-text">
                                    @evento.Mensaje
                                </span>
                            </td>

                            <td class="text-end">
                                <a asp-controller="Equipos"
                                       asp-action="Details"
                                       asp-route-id="@evento.EquipoId"
                                       class="btn btn-sm btn-outline-primary metro-action-btn">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
