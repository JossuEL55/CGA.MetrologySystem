@model CGA.MetrologySystem.Domain.Entities.ConfiguracionControlEquipo

@{
    ViewData["Title"] = "Detalle de configuración de control";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Detalle de configuración de control</h2>
        <p class="page-subtitle">
            Consulta la regla de periodicidad configurada para el equipo y tipo de evento.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="form-card">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Equipo</label>
            <input class="form-control readonly-highlight"
                   value="@Model.Equipo.Codigo - @Model.Equipo.Nombre"
                   readonly />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Tipo de evento</label>
            <input class="form-control readonly-highlight"
                   value="@Model.TipoEventoMetrologico.Nombre"
                   readonly />
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Periodicidad</label>
            <input class="form-control readonly-highlight"
                   value="@(Model.PeriodicidadValor.HasValue && !string.IsNullOrWhiteSpace(Model.PeriodicidadUnidad)
                                                       ? $"{Model.PeriodicidadValor} {Model.PeriodicidadUnidad}"
                                                       : "Sin periodicidad")"
                   readonly />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Requiere control</label>
            <input class="form-control readonly-highlight"
                   value="@(Model.RequiereControl ? "Sí" : "No")"
                   readonly />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Permite por ingreso</label>
            <input class="form-control readonly-highlight"
                   value="@(Model.PermitePorIngreso ? "Sí" : "No")"
                   readonly />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Activo</label>
        <input class="form-control readonly-highlight"
               value="@(Model.Activo ? "Activo" : "Inactivo")"
               readonly />
    </div>

    <div class="alert alert-secondary mt-3">
        Esta configuración será consultada por el motor de reglas para determinar la próxima fecha
        de control, detectar atrasos y alimentar la semaforización del equipo.
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>

        <a asp-action="Edit"
               asp-route-id="@Model.ConfiguracionControlEquipoId"
               class="btn btn-primary">
            Editar
        </a>
    </div>
</div>