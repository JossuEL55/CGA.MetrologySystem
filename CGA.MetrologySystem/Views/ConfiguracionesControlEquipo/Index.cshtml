@model IEnumerable<CGA.MetrologySystem.Domain.Entities.ConfiguracionControlEquipo>

@{
    ViewData["Title"] = "Configuraciones de control";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Configuraciones de control</h2>
        <p class="page-subtitle">
            Define la periodicidad y reglas base de control metrológico por equipo y tipo de evento.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">Nueva configuración</a>
</div>

<div class="form-card">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Equipo</th>
                <th>Tipo de evento</th>
                <th>Periodicidad</th>
                <th>Requiere control</th>
                <th>Permite por ingreso</th>
                <th>Activo</th>
                <th style="width: 230px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var configuracion in Model)
            {
                <tr>
                    <td>
                        <strong>@configuracion.Equipo.Codigo</strong><br />
                        <span class="text-muted">@configuracion.Equipo.Nombre</span>
                    </td>

                    <td>@configuracion.TipoEventoMetrologico.Nombre</td>

                    <td>
                        @if (configuracion.PeriodicidadValor.HasValue && !string.IsNullOrWhiteSpace(configuracion.PeriodicidadUnidad))
                        {
                            <span>@configuracion.PeriodicidadValor @configuracion.PeriodicidadUnidad</span>
                        }
                        else
                        {
                            <span class="text-muted">Sin periodicidad</span>
                        }
                    </td>

                    <td>
                        @if (configuracion.RequiereControl)
                        {
                            <span class="badge bg-success">Sí</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>

                    <td>
                        @if (configuracion.PermitePorIngreso)
                        {
                            <span class="badge bg-info">Sí</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>

                    <td>
                        @if (configuracion.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </td>

                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Details"
                                   asp-route-id="@configuracion.ConfiguracionControlEquipoId"
                                   class="btn btn-outline-info btn-sm">
                                Detalle
                            </a>

                            <a asp-action="Edit"
                                   asp-route-id="@configuracion.ConfiguracionControlEquipoId"
                                   class="btn btn-outline-primary btn-sm">
                                Editar
                            </a>

                            <a asp-action="Delete"
                                   asp-route-id="@configuracion.ConfiguracionControlEquipoId"
                                   class="btn btn-outline-danger btn-sm">
                                Eliminar
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>