@model CGA.MetrologySystem.Models.ConfiguracionControlEquipoViewModel

@{
    ViewData["Title"] = "Editar configuración de control";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Editar configuración de control</h2>
        <p class="page-subtitle">
            Actualiza la periodicidad y parámetros de control metrológico asociados al equipo.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Volver
    </a>
</div>

<form asp-action="Edit"
      asp-route-id="@Model.ConfiguracionControlEquipoId"
      method="post"
      class="form-card">

    <input type="hidden" asp-for="ConfiguracionControlEquipoId" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

    <div class="row">

        <div class="col-md-6 mb-4">
            <label asp-for="EquipoId" class="form-label fw-semibold"></label>

            <select asp-for="EquipoId"
                    asp-items="Model.Equipos"
                    class="form-select">
                <option value="">Seleccione un equipo...</option>
            </select>

            <span asp-validation-for="EquipoId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-4">
            <label asp-for="TipoEventoMetrologicoId" class="form-label fw-semibold"></label>

            <select asp-for="TipoEventoMetrologicoId"
                    asp-items="Model.TiposEventoMetrologico"
                    class="form-select">
                <option value="">Seleccione un tipo de evento...</option>
            </select>

            <span asp-validation-for="TipoEventoMetrologicoId" class="text-danger"></span>
        </div>

    </div>

    <div class="row">

        <div class="col-md-4 mb-4 control-periodicidad-field">
            <label asp-for="PeriodicidadValor" class="form-label fw-semibold"></label>

            <input asp-for="PeriodicidadValor"
                   type="number"
                   min="1"
                   class="form-control"
                   placeholder="Ej: 4" />

            <span asp-validation-for="PeriodicidadValor" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-4 control-periodicidad-field">
            <label asp-for="PeriodicidadUnidad" class="form-label fw-semibold"></label>

            <select asp-for="PeriodicidadUnidad"
                    asp-items="Model.UnidadesPeriodicidad"
                    class="form-select">
                <option value="">Seleccione una unidad...</option>
            </select>

            <span asp-validation-for="PeriodicidadUnidad" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-4">
            <label class="form-label fw-semibold">
                Estado de configuración
            </label>

            <div class="content-card h-100 d-flex align-items-center">
                <div class="form-check">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label fw-semibold"></label>
                </div>
            </div>
        </div>

    </div>

    <hr class="my-4" />

    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="content-card h-100">

                <label class="form-label fw-semibold">
                    ¿Requiere este control?
                </label>

                <div class="form-check mb-2">
                    <input class="form-check-input control-requiere-option"
                           type="radio"
                           asp-for="RequiereControl"
                           id="RequiereControlSi"
                           value="true" />
                    <label class="form-check-label fw-semibold" for="RequiereControlSi">
                        Sí, requiere control
                    </label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input control-requiere-option"
                           type="radio"
                           asp-for="RequiereControl"
                           id="RequiereControlNo"
                           value="false" />
                    <label class="form-check-label fw-semibold" for="RequiereControlNo">
                        No requiere control
                    </label>
                </div>

                <p class="text-muted small mb-0">
                    Seleccione si este equipo debe pasar por este control metrológico.
                </p>

                <div id="NoRequiereControlHelp" class="alert alert-info mt-3 mb-0 d-none">
                    Este control quedará marcado como No requiere control y no será
                    considerado como vencido ni pendiente.
                </div>

            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="content-card h-100">

                <div class="form-check mb-2">
                    <input asp-for="PermitePorIngreso"
                           class="form-check-input"
                           id="PermitePorIngreso" />

                    <label asp-for="PermitePorIngreso"
                           class="form-check-label fw-semibold">
                    </label>
                </div>

                <p class="text-muted small mb-0">
                    Permite registrar eventos por ingreso del equipo además del
                    control periódico definido.
                </p>

            </div>
        </div>

    </div>

    <div class="alert alert-info mt-2">
        Al modificar esta configuración, los próximos cálculos del motor de reglas usarán estos nuevos valores.
        No se alteran automáticamente los eventos históricos ya registrados.
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">

        <a asp-action="Index" class="btn btn-outline-secondary">
            Cancelar
        </a>

        <button type="submit" class="btn btn-primary">
            Guardar cambios
        </button>

    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (() => {
            const requiereOptions = document.querySelectorAll('.control-requiere-option');
            const periodicidadFields = document.querySelectorAll('.control-periodicidad-field input, .control-periodicidad-field select');
            const permitePorIngreso = document.getElementById('PermitePorIngreso');
            const ayudaNoRequiere = document.getElementById('NoRequiereControlHelp');

            const actualizarEstado = () => {
                const requiereControl = document.querySelector('.control-requiere-option:checked')?.value === 'true';

                periodicidadFields.forEach(field => {
                    field.disabled = !requiereControl;
                    if (!requiereControl) {
                        field.value = '';
                    }
                });

                if (permitePorIngreso) {
                    permitePorIngreso.disabled = !requiereControl;
                    if (!requiereControl) {
                        permitePorIngreso.checked = false;
                    }
                }

                ayudaNoRequiere?.classList.toggle('d-none', requiereControl);
            };

            requiereOptions.forEach(option => option.addEventListener('change', actualizarEstado));
            actualizarEstado();
        })();
    </script>
}
