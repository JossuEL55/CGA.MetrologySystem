@model CGA.MetrologySystem.Models.ConfiguracionControlEquipoViewModel

@{
    ViewData["Title"] = "Editar configuración de control";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Editar configuración de control</h2>
        <p class="page-subtitle">
            Actualiza la periodicidad y parámetros de control metrológico asociados al equipo.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<form asp-action="Edit"
      asp-route-id="@Model.ConfiguracionControlEquipoId"
      method="post"
      class="form-card">

    <input type="hidden" asp-for="ConfiguracionControlEquipoId" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="EquipoId" class="form-label fw-semibold"></label>
            <select asp-for="EquipoId"
                    asp-items="Model.Equipos"
                    class="form-control">
                <option value="">Seleccione un equipo...</option>
            </select>
            <span asp-validation-for="EquipoId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="TipoEventoMetrologicoId" class="form-label fw-semibold"></label>
            <select asp-for="TipoEventoMetrologicoId"
                    asp-items="Model.TiposEventoMetrologico"
                    class="form-control">
                <option value="">Seleccione un tipo de evento...</option>
            </select>
            <span asp-validation-for="TipoEventoMetrologicoId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="PeriodicidadValor" class="form-label fw-semibold"></label>
            <input asp-for="PeriodicidadValor"
                   class="form-control"
                   type="number"
                   min="1"
                   placeholder="Ej: 4" />
            <span asp-validation-for="PeriodicidadValor" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="PeriodicidadUnidad" class="form-label fw-semibold"></label>
            <select asp-for="PeriodicidadUnidad"
                    asp-items="Model.UnidadesPeriodicidad"
                    class="form-control">
                <option value="">Seleccione una unidad...</option>
            </select>
            <span asp-validation-for="PeriodicidadUnidad" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Estado de configuración</label>

            <div class="form-check mt-2">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="p-3 border rounded">
                <div class="form-check">
                    <input asp-for="RequiereControl" class="form-check-input" />
                    <label asp-for="RequiereControl" class="form-check-label fw-semibold"></label>
                </div>
                <small class="text-muted">
                    Indica si este equipo debe ser controlado para el tipo de evento seleccionado.
                </small>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="p-3 border rounded">
                <div class="form-check">
                    <input asp-for="PermitePorIngreso" class="form-check-input" />
                    <label asp-for="PermitePorIngreso" class="form-check-label fw-semibold"></label>
                </div>
                <small class="text-muted">
                    Útil cuando el evento puede registrarse por ingreso del equipo, además del control periódico.
                </small>
            </div>
        </div>
    </div>

    <div class="alert alert-info mt-3">
        Al modificar esta configuración, los próximos cálculos del motor de reglas usarán estos nuevos valores.
        No se alteran automáticamente los eventos históricos ya registrados.
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}