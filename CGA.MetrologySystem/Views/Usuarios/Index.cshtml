@model CGA.MetrologySystem.Models.Usuarios.UsuariosIndexViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using CGA.MetrologySystem.Infrastructure.Identity

@{
    ViewData["Title"] = "Usuarios";
    var roles = ViewBag.Roles as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var hayFiltros = !string.IsNullOrWhiteSpace(Model.Busqueda) ||
        !string.IsNullOrWhiteSpace(Model.Rol) ||
        !string.IsNullOrWhiteSpace(Model.Estado);
}

@functions {
    private static string ObtenerInicial(string nombre)
    {
        return string.IsNullOrWhiteSpace(nombre) ? "U" : nombre.Trim()[0].ToString().ToUpperInvariant();
    }

    private static string ObtenerClaseRol(string rolCodigo)
    {
        return rolCodigo switch
        {
            RolesSistema.AdministradorSistema => "role-badge-system",
            RolesSistema.AdministradorMetrologico => "role-badge-metrology",
            RolesSistema.Tecnico => "role-badge-tech",
            _ => "role-badge-metrology"
        };
    }
}

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success">@TempData["MensajeExito"]</div>
}

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">@TempData["MensajeError"]</div>
}

<section class="security-hero mb-4">
    <div class="position-relative">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <div class="security-eyebrow">Seguridad y accesos</div>
                <h2 class="page-title mb-2">Gesti&oacute;n de usuarios</h2>
                <p class="security-subtitle mb-0">
                    Administra cuentas, roles, estado operativo y acciones sensibles del sistema.
                </p>
            </div>
            <a asp-action="Crear" class="btn btn-warning fw-bold">Crear usuario</a>
        </div>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-2">
        <div class="metric-card">
            <div class="metric-card-label">Total</div>
            <div class="metric-card-value mt-3">@Model.TotalUsuarios</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="metric-card">
            <div class="metric-card-label">Activos</div>
            <div class="metric-card-value text-success mt-3">@Model.UsuariosActivos</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="metric-card">
            <div class="metric-card-label">Inactivos</div>
            <div class="metric-card-value text-danger mt-3">@Model.UsuariosInactivos</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="metric-card">
            <div class="metric-card-label">Admin. sistema</div>
            <div class="metric-card-value mt-3">@Model.TotalAdministradores</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="metric-card">
            <div class="metric-card-label">Admin. metrol&oacute;gico</div>
            <div class="metric-card-value mt-3">@Model.TotalAdministradoresMetrologicos</div>
        </div>
    </div>
    <div class="col-md-6 col-xl-2">
        <div class="metric-card">
            <div class="metric-card-label">T&eacute;cnicos</div>
            <div class="metric-card-value mt-3">@Model.TotalTecnicos</div>
        </div>
    </div>
</div>

<form method="get" class="user-filter-card mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-lg-5">
            <label class="form-label" for="busqueda">Buscar usuario</label>
            <input id="busqueda"
                   name="busqueda"
                   value="@Model.Busqueda"
                   class="form-control"
                   placeholder="Nombre completo o correo" />
        </div>

        <div class="col-lg-3">
            <label class="form-label" for="rol">Rol</label>
            <select id="rol" name="rol" class="form-select">
                <option value="">Todos los roles</option>
                @foreach (var rol in roles)
                {
                    <option value="@rol.Value" selected="@(Model.Rol == rol.Value)">
                        @rol.Text
                    </option>
                }
            </select>
        </div>

        <div class="col-lg-2">
            <label class="form-label" for="estado">Estado</label>
            <select id="estado" name="estado" class="form-select">
                <option value="">Todos</option>
                <option value="activo" selected="@(Model.Estado == "activo")">Activos</option>
                <option value="inactivo" selected="@(Model.Estado == "inactivo")">Inactivos</option>
            </select>
        </div>

        <div class="col-lg-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-fill">Filtrar</button>
            @if (hayFiltros)
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
            }
        </div>
    </div>
</form>

<section class="user-table-card">
    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap p-3 border-bottom">
        <div>
            <h5 class="mb-1">Usuarios registrados</h5>
            <p class="text-muted mb-0">@Model.Usuarios.Count usuario(s) seg&uacute;n los filtros actuales.</p>
        </div>
        @if (hayFiltros)
        {
            <span class="status-badge status-active">Filtro activo</span>
        }
    </div>

    <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Creaci&oacute;n</th>
                    <th>&Uacute;ltimo acceso</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Usuarios.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            No se encontraron usuarios con los filtros seleccionados.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var usuario in Model.Usuarios)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="user-avatar">@ObtenerInicial(usuario.NombreCompleto)</div>
                                    <div>
                                        <div class="fw-bold">@usuario.NombreCompleto</div>
                                        <div class="text-muted small">@usuario.Correo</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="role-badge @ObtenerClaseRol(usuario.RolCodigo)">@usuario.Rol</span>
                            </td>
                            <td>
                                @if (usuario.Activo)
                                {
                                    <span class="status-badge status-active">Activo</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactivo</span>
                                }
                            </td>
                            <td class="text-muted">@usuario.FechaCreacionTexto</td>
                            <td class="text-muted">@usuario.UltimoAccesoTexto</td>
                            <td>
                                <div class="user-action-group">
                                    <a asp-action="Details" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                                    <a asp-action="Editar" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                    <a asp-action="ResetPassword" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-dark">Clave</a>
                                    @if (usuario.Activo)
                                    {
                                        <a asp-action="CambiarEstado"
                                           asp-route-id="@usuario.Id"
                                           class="btn btn-sm btn-outline-warning"
                                           onclick="return confirm('Desactivar este usuario?');">
                                            Desactivar
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="CambiarEstado"
                                           asp-route-id="@usuario.Id"
                                           class="btn btn-sm btn-outline-success"
                                           onclick="return confirm('Activar este usuario?');">
                                            Activar
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
