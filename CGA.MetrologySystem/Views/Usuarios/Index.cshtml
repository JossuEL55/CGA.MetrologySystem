@model CGA.MetrologySystem.Models.Usuarios.UsuariosIndexViewModel

@{
    ViewData["Title"] = "Usuarios del sistema";
}

<div class="container mt-4">

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Gestión de usuarios</h2>
            <p class="text-muted mb-0">Administra accesos, roles y estados del sistema.</p>
        </div>
        <a asp-action="Crear" class="btn btn-primary">Crear usuario</a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Total usuarios</h6>
                    <h3 class="mb-0">@Model.TotalUsuarios</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Usuarios activos</h6>
                    <h3 class="mb-0 text-success">@Model.UsuariosActivos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Usuarios inactivos</h6>
                    <h3 class="mb-0 text-danger">@Model.UsuariosInactivos</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Administradores</h6>
                    <h3 class="mb-0">@Model.TotalAdministradores</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Correo</th>
                            <th>Nombre completo</th>
                            <th>Estado</th>
                            <th>Rol</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model.Usuarios)
                        {
                            <tr>
                                <td class="fw-semibold">@usuario.Correo</td>
                                <td>@usuario.NombreCompleto</td>
                                <td>
                                    @if (usuario.Activo)
                                    {
                                        <span class="badge rounded-pill bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    @if (usuario.Rol == "Administrador")
                                    {
                                        <span class="badge rounded-pill bg-dark">Administrador</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">@usuario.Rol</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                                        <a asp-action="Editar" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-primary">
                                            Editar
                                        </a>

                                        <a asp-action="ResetPassword" asp-route-id="@usuario.Id"
                                               class="btn btn-sm btn-outline-secondary"
                                               onclick="return confirm('¿Está seguro de que desea restablecer la contraseña de este usuario?');">
                                            Reset clave
                                        </a>

                                        @if (usuario.Activo)
                                        {
                                            <a asp-action="CambiarEstado" asp-route-id="@usuario.Id"
                                                   class="btn btn-sm btn-outline-warning"
                                                   onclick="return confirm('¿Está seguro de que desea desactivar este usuario?');">
                                                Desactivar
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="CambiarEstado" asp-route-id="@usuario.Id"
                                                   class="btn btn-sm btn-outline-success"
                                                   onclick="return confirm('¿Está seguro de que desea activar este usuario?');">
                                                Activar
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>