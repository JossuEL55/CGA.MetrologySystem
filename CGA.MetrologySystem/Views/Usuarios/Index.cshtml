@model CGA.MetrologySystem.Models.Usuarios.UsuariosIndexViewModel

@{
    ViewData["Title"] = "Usuarios";
}

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success">@TempData["MensajeExito"]</div>
}

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">@TempData["MensajeError"]</div>
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Gestión de usuarios</h2>
        <p class="page-subtitle">Administra accesos, roles y estados del sistema.</p>
    </div>
    <a asp-action="Crear" class="btn btn-primary">Crear usuario</a>
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="dashboard-card p-3">
            <h6 class="text-muted">Total usuarios</h6>
            <h3>@Model.TotalUsuarios</h3>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="dashboard-card p-3">
            <h6 class="text-muted">Activos</h6>
            <h3 class="text-success">@Model.UsuariosActivos</h3>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="dashboard-card p-3">
            <h6 class="text-muted">Inactivos</h6>
            <h3 class="text-danger">@Model.UsuariosInactivos</h3>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="dashboard-card p-3">
            <h6 class="text-muted">Administradores</h6>
            <h3>@Model.TotalAdministradores</h3>
        </div>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Correo</th>
                    <th>Nombre</th>
                    <th>Estado</th>
                    <th>Rol</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var usuario in Model.Usuarios)
                {
                    <tr>
                        <td class="fw-semibold">@usuario.Correo</td>
                        <td>@usuario.NombreCompleto</td>

                        <td>
                            @if (usuario.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>

                        <td>
                            <span class="badge bg-secondary">@usuario.Rol</span>
                        </td>

                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2 flex-wrap">

                                <a asp-action="Editar" asp-route-id="@usuario.Id"
                                       class="btn btn-sm btn-outline-primary">
                                    Editar
                                </a>

                                <a asp-action="ResetPassword" asp-route-id="@usuario.Id"
                                       class="btn btn-sm btn-outline-secondary"
                                       onclick="return confirm('¿Restablecer contraseña?');">
                                    Reset
                                </a>

                                @if (usuario.Activo)
                                {
                                    <a asp-action="CambiarEstado" asp-route-id="@usuario.Id"
                                           class="btn btn-sm btn-outline-warning">
                                        Desactivar
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="CambiarEstado" asp-route-id="@usuario.Id"
                                           class="btn btn-sm btn-outline-success">
                                        Activar
                                    </a>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>