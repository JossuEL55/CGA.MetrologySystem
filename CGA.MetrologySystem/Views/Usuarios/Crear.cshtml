@model CGA.MetrologySystem.Models.Usuarios.UsuarioCrearViewModel

@{
    ViewData["Title"] = "Crear usuario";
}

<section class="security-hero mb-4">
    <div class="position-relative">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <div class="security-eyebrow">Seguridad y accesos</div>
                <h2 class="page-title mb-2">Crear usuario</h2>
                <p class="security-subtitle mb-0">
                    Registra una nueva cuenta, define su rol operativo y deja habilitado el acceso inicial.
                </p>
            </div>
            <a asp-action="Index" class="btn btn-light fw-bold">Volver</a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="security-panel">
            <form asp-action="Crear" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-4">
                    <h5 class="security-panel-title mb-1">Datos de la cuenta</h5>
                    <p class="text-muted mb-0">El correo ser&aacute; usado como usuario de inicio de sesi&oacute;n.</p>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" class="form-control" placeholder="usuario@cga.com.ec" autocomplete="email" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NombreCompleto" class="form-label"></label>
                        <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre y apellido" autocomplete="name" />
                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="mb-4">
                    <h5 class="security-panel-title mb-1">Credenciales iniciales</h5>
                    <p class="text-muted mb-0">El usuario deber&aacute; cambiar su contrase&ntilde;a al ingresar por primera vez.</p>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Contrasena" class="form-label"></label>
                        <input asp-for="Contrasena" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmarContrasena" class="form-label"></label>
                        <input asp-for="ConfirmarContrasena" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmarContrasena" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="mb-4">
                    <h5 class="security-panel-title mb-1">Rol y disponibilidad</h5>
                    <p class="text-muted mb-0">Asigna el alcance funcional seg&uacute;n la responsabilidad real del usuario.</p>
                </div>

                <div class="row g-3">
                    <div class="col-md-7">
                        <label asp-for="Rol" class="form-label"></label>
                        <select asp-for="Rol" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">Seleccione un rol</option>
                        </select>
                        <span asp-validation-for="Rol" class="text-danger"></span>
                    </div>

                    <div class="col-md-5 d-flex align-items-end">
                        <div class="detail-tile w-100">
                            <div class="form-check">
                                <input asp-for="Activo" class="form-check-input" />
                                <label asp-for="Activo" class="form-check-label fw-bold"></label>
                            </div>
                            <div class="text-muted small mt-2">Permite iniciar sesi&oacute;n cuando la cuenta est&eacute; creada.</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 flex-wrap">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar usuario</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="security-panel h-100">
            <h5 class="security-panel-title mb-3">Alcance de roles</h5>
            <div class="d-flex flex-column gap-3">
                <div class="role-info-item">
                    <div class="fw-bold">Administrador del sistema</div>
                    <p class="text-muted mb-0 small">Gestiona usuarios, accesos, auditor&iacute;a administrativa y supervisi&oacute;n general.</p>
                </div>
                <div class="role-info-item">
                    <div class="fw-bold">Administrador metrol&oacute;gico</div>
                    <p class="text-muted mb-0 small">Administra equipos, controles, cat&aacute;logos, calibraciones y reglas metrol&oacute;gicas.</p>
                </div>
                <div class="role-info-item">
                    <div class="fw-bold">T&eacute;cnico</div>
                    <p class="text-muted mb-0 small">Consulta equipos y registra verificaciones o mantenimientos permitidos.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
