@model CGA.MetrologySystem.Models.Usuarios.UsuarioEditarViewModel

@{
    ViewData["Title"] = "Editar usuario";
}

<section class="security-hero mb-4">
    <div class="position-relative">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
            <div>
                <div class="security-eyebrow">Seguridad y accesos</div>
                <h2 class="page-title mb-2">Editar usuario</h2>
                <p class="security-subtitle mb-0">
                    Actualiza datos visibles, rol asignado y disponibilidad de la cuenta.
                </p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light fw-bold">Ver detalle</a>
                <a asp-action="Index" class="btn btn-outline-light fw-bold">Volver</a>
            </div>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="security-panel">
            <form asp-action="Editar" method="post">
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-4">
                    <h5 class="security-panel-title mb-1">Datos del usuario</h5>
                    <p class="text-muted mb-0">El correo se mantiene fijo para conservar trazabilidad.</p>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" class="form-control" readonly />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NombreCompleto" class="form-label"></label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="mb-4">
                    <h5 class="security-panel-title mb-1">Permisos y disponibilidad</h5>
                    <p class="text-muted mb-0">Los cambios quedan registrados en auditor&iacute;a de usuarios.</p>
                </div>

                <div class="row g-3">
                    <div class="col-md-7">
                        <label asp-for="Rol" class="form-label"></label>
                        <select asp-for="Rol" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">Seleccione un rol</option>
                        </select>
                        <span asp-validation-for="Rol" class="text-danger"></span>
                    </div>

                    <div class="col-md-5 d-flex align-items-end">
                        <div class="detail-tile w-100">
                            <div class="form-check">
                                <input asp-for="Activo" class="form-check-input" />
                                <label asp-for="Activo" class="form-check-label fw-bold"></label>
                            </div>
                            <div class="text-muted small mt-2">Al desactivar, el usuario conserva trazabilidad pero no opera el sistema.</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 flex-wrap">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Ver detalle</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="security-panel h-100">
            <h5 class="security-panel-title mb-3">Criterios de seguridad</h5>
            <div class="d-flex flex-column gap-3">
                <div class="role-info-item">
                    <div class="fw-bold">Protecci&oacute;n administrativa</div>
                    <p class="text-muted mb-0 small">El sistema evita desactivar o cambiar el &uacute;ltimo administrador activo.</p>
                </div>
                <div class="role-info-item">
                    <div class="fw-bold">Trazabilidad</div>
                    <p class="text-muted mb-0 small">La edici&oacute;n queda registrada para seguimiento de cambios sensibles.</p>
                </div>
                <div class="role-info-item">
                    <div class="fw-bold">Contrase&ntilde;a</div>
                    <p class="text-muted mb-0 small">El restablecimiento se gestiona desde una acci&oacute;n separada.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
