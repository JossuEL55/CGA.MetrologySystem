@model CGA.MetrologySystem.Models.Usuarios.UsuarioEditarViewModel

@{
    ViewData["Title"] = "Editar usuario";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Editar usuario</h2>
            <p class="text-muted mb-0">Actualiza la información, rol y estado del usuario seleccionado.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Editar" method="post">
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Correo" class="form-label fw-semibold"></label>
                        <input asp-for="Correo" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Rol" class="form-label fw-semibold"></label>
                        <select asp-for="Rol" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">Seleccione un rol</option>
                        </select>
                        <span asp-validation-for="Rol" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check mt-2">
                            <input asp-for="Activo" class="form-check-input" />
                            <label asp-for="Activo" class="form-check-label fw-semibold"></label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}