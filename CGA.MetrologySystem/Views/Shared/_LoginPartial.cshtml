@using CGA.MetrologySystem.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UsuarioSistema> SignInManager
@inject UserManager<UsuarioSistema> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var usuario = await UserManager.GetUserAsync(User);
        var nombreMostrar = !string.IsNullOrWhiteSpace(usuario?.NombreCompleto)
            ? usuario.NombreCompleto
            : UserManager.GetUserName(User);

        <li class="nav-item">
            <span class="nav-link text-white fw-semibold">
                @UserManager.GetUserAsync(User).Result?.NombreCompleto
            </span>
        </li>
        <li class="nav-item">
            <form class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post">
                <button type="submit" class="nav-link btn btn-link text-white border-0">
                    Cerrar sesión
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Auth" asp-action="Login">
                Iniciar sesión
            </a>
        </li>
    }
</ul>