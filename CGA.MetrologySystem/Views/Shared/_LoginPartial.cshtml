@using CGA.MetrologySystem.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UsuarioSistema> SignInManager
@inject UserManager<UsuarioSistema> UserManager

@{
    UsuarioSistema? usuario = null;
    string nombreMostrar = string.Empty;

    if (SignInManager.IsSignedIn(User))
    {
        usuario = await UserManager.GetUserAsync(User);
        nombreMostrar = !string.IsNullOrWhiteSpace(usuario?.NombreCompleto)
            ? usuario.NombreCompleto
            : UserManager.GetUserName(User) ?? "Usuario";
    }
}

<div class="user-panel">
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="user-panel-info">
            <div class="user-panel-avatar">
                @nombreMostrar.Substring(0, 1).ToUpper()
            </div>

            <div class="user-panel-text">
                <span class="user-panel-label">Sesión activa</span>
                <span class="user-panel-name">@nombreMostrar</span>
            </div>
        </div>

        <form asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
              method="post"
              class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-sm user-panel-logout">
                Cerrar sesión
            </button>
        </form>
    }
    else
    {
        <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">
            Iniciar sesión
        </a>
    }
</div>