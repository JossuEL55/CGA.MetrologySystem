@model CGA.MetrologySystem.Models.Perfil.PerfilViewModel

@{
    ViewData["Title"] = "Mi perfil";
}

<div class="page-header">
    <h2 class="page-title">Mi perfil</h2>
    <p class="page-subtitle">
        Consulta y actualiza tu información personal dentro del sistema.
    </p>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success">@TempData["MensajeExito"]</div>
}

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger">@TempData["MensajeError"]</div>
}

<div class="form-card">
    <form asp-action="Index" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Correo" class="form-label fw-semibold"></label>
                <input asp-for="Correo" class="form-control" readonly />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                <input asp-for="NombreCompleto" class="form-control" />
                <span asp-validation-for="NombreCompleto" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Rol" class="form-label fw-semibold"></label>
                <input asp-for="Rol" class="form-control" readonly />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Estado</label>
                <input class="form-control" value="@(Model.Activo ? "Activo" : "Inactivo")" readonly />
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a asp-action="CambiarContrasena" class="btn btn-outline-secondary">Cambiar contraseña</a>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}