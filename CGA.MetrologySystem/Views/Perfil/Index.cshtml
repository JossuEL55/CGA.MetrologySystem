@model CGA.MetrologySystem.Models.Perfil.PerfilViewModel

@{
    ViewData["Title"] = "Mi perfil";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Mi perfil</h2>
            <p class="text-muted mb-0">Consulta y actualiza tu información personal dentro del sistema.</p>
        </div>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Index" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Correo" class="form-label fw-semibold"></label>
                        <input asp-for="Correo" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Rol" class="form-label fw-semibold"></label>
                        <input asp-for="Rol" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Estado</label>
                        <input class="form-control" value="@(Model.Activo ? "Activo" : "Inactivo")" readonly />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <a asp-action="CambiarContrasena" class="btn btn-outline-secondary">Cambiar contraseña</a>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}