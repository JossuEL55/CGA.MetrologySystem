@model IEnumerable<CGA.MetrologySystem.Domain.Entities.EventoMantenimientoDato>

@{
    ViewData["Title"] = "Mantenimientos";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Mantenimientos</h2>
        <p class="page-subtitle">
            Consulta el historial de mantenimientos registrados, su estado operativo y la documentación generada.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Registrar mantenimiento
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="form-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h5 class="mb-2">Aún no hay mantenimientos registrados</h5>
            <p class="text-muted mb-4">
                Cuando se registre un mantenimiento, aparecerá aquí junto con su equipo, fecha, responsable y PDF generado.
            </p>
            <a asp-action="Create" class="btn btn-primary">
                Registrar primer mantenimiento
            </a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
                <h5 class="mb-1">Historial técnico</h5>
                <p class="text-muted mb-0">
                    Cada registro conserva trazabilidad del evento, PDF interno y control documental en Drive.
                </p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Equipo</th>
                        <th>Fecha</th>
                        <th>Próxima fecha</th>
                        <th>Tipo</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th>PDF</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var evento = item.EventoMetrologico;
                        var estado = evento.EstadoEquipoResultado ?? "Sin estado";

                        var badgeClass = estado switch
                        {
                            "Operativo" => "bg-success",
                            "No Operativo" => "bg-danger",
                            "Fuera de Servicio" => "bg-dark",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td>
                                <div class="fw-semibold">@evento.Equipo?.Codigo</div>
                                <div class="text-muted small">@evento.Equipo?.Nombre</div>
                            </td>

                            <td>
                                @evento.FechaEvento.ToString("yyyy-MM-dd")
                            </td>

                            <td>
                                @if (evento.FechaProxima.HasValue)
                                {
                                    <span>@evento.FechaProxima.Value.ToString("yyyy-MM-dd")</span>
                                }
                                else
                                {
                                    <span class="text-muted">No definida</span>
                                }
                            </td>

                            <td>
                                @item.TipoMantenimiento?.Nombre
                            </td>

                            <td>
                                @evento.ResponsableInterno?.NombreCompleto
                            </td>

                            <td>
                                <span class="badge @badgeClass">
                                    @estado
                                </span>

                                @if (evento.EsExtraordinario)
                                {
                                    <span class="badge bg-warning text-dark ms-1">
                                        Extraordinario
                                    </span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.RutaPdf))
                                {
                                    <a href="@item.RutaPdf" target="_blank" class="btn btn-outline-primary btn-sm">
                                        Ver PDF
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">Sin PDF</span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                           asp-route-id="@item.EventoMantenimientoDatoId"
                                           class="btn btn-outline-secondary btn-sm">
                                        Detalle
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.EventoMantenimientoDatoId"
                                           class="btn btn-outline-primary btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.EventoMantenimientoDatoId"
                                           class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>