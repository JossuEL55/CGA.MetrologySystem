@model IEnumerable<CGA.MetrologySystem.Domain.Entities.EventoMantenimientoDato>

@{
    ViewData["Title"] = "Mantenimientos";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Mantenimientos</h2>
        <p class="page-subtitle">Consulta y administra los mantenimientos registrados.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Nuevo mantenimiento</a>
</div>

<div class="form-card">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Equipo</th>
                <th>Tipo mantenimiento</th>
                <th>Fecha</th>
                <th>Próxima fecha</th>
                <th>Responsable</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.EventoMetrologico.Equipo.Codigo - @item.EventoMetrologico.Equipo.Nombre
                    </td>
                    <td>@item.TipoMantenimiento.Nombre</td>
                    <td>@item.EventoMetrologico.FechaEvento.ToString("yyyy-MM-dd")</td>
                    <td>
                        @(item.EventoMetrologico.FechaProxima.HasValue
                            ? item.EventoMetrologico.FechaProxima.Value.ToString("yyyy-MM-dd")
                            : "N/D")
                    </td>
                    <td>@item.EventoMetrologico.ResponsableInterno.NombreCompleto</td>
                    <td>
                        <span class="badge bg-secondary">
                            @(item.EventoMetrologico.EstadoEquipoResultado ?? "Sin estado")
                        </span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.EventoMantenimientoDatoId" class="btn btn-outline-info btn-sm">Ver</a>
                        <a asp-action="Edit" asp-route-id="@item.EventoMantenimientoDatoId" class="btn btn-outline-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.EventoMantenimientoDatoId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>