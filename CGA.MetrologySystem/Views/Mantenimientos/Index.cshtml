@model IEnumerable<CGA.MetrologySystem.Domain.Entities.EventoMantenimientoDato>

@{
    ViewData["Title"] = "Mantenimientos";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="page-title">Mantenimientos</h2>
        <p class="page-subtitle">
            Consulta y administra los mantenimientos registrados para los equipos.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Nuevo mantenimiento
    </a>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Equipo</th>
                    <th>Tipo mantenimiento</th>
                    <th>Fecha</th>
                    <th>Próxima fecha</th>
                    <th>Responsable</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No existen mantenimientos registrados.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.EventoMetrologico.Equipo.Codigo</strong><br />
                                <span class="text-muted">@item.EventoMetrologico.Equipo.Nombre</span>
                            </td>

                            <td>@item.TipoMantenimiento.Nombre</td>

                            <td>@item.EventoMetrologico.FechaEvento.ToString("yyyy-MM-dd")</td>

                            <td>
                                @(item.EventoMetrologico.FechaProxima.HasValue
                                    ? item.EventoMetrologico.FechaProxima.Value.ToString("yyyy-MM-dd")
                                    : "N/D")
                            </td>

                            <td>@item.EventoMetrologico.ResponsableInterno.NombreCompleto</td>

                            <td>
                                <span class="badge bg-light text-dark border">
                                    @(item.EventoMetrologico.EstadoEquipoResultado ?? "Sin estado")
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="section-actions justify-content-end">
                                    <a asp-action="Details"
                                           asp-route-id="@item.EventoMantenimientoDatoId"
                                           class="btn btn-outline-info btn-sm">
                                        Ver
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.EventoMantenimientoDatoId"
                                           class="btn btn-outline-primary btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.EventoMantenimientoDatoId"
                                           class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>